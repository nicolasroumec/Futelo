@page "/dashboard"
@inherits LocalizedComponentBase
@attribute [Authorize]

<PageTitle>Dashboard - Futelo</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3>@Lang.Get("dashboard.title")</h3>
    <a href="/vaults/create" class="btn btn-primary">@Lang.Get("dashboard.newVault")</a>
</div>

@if (isLoading)
{
    <SkeletonCards Count="3" Columns="3" />
}
else if (vaults.Count == 0)
{
    <EmptyState Title="@Lang.Get("dashboard.emptyTitle")"
                Message="@Lang.Get("dashboard.emptySubtitle")"
                ActionLabel="@Lang.Get("dashboard.newVault")"
                ActionHref="/vaults/create">
        <Icon>🎮</Icon>
    </EmptyState>
}
else
{
    <div class="row row-cols-1 row-cols-md-3 g-4">
        @foreach (var vault in vaults)
        {
            <div class="col">
                <div class="card card-glass h-100">
                    <div class="card-body">
                        <h5 class="card-title fw-bold mb-1">@vault.Name</h5>
                        <div class="d-flex align-items-center gap-2 mb-3">
                            <span class="badge bg-secondary">@vault.Players.Count @Lang.Get("dashboard.players")</span>
                            @if (vault.HasActiveSeason && vault.ActiveSeasonId.HasValue)
                            {
                                <a href="/seasons/@vault.ActiveSeasonId" class="badge badge-active-season text-decoration-none">@Lang.Get("dashboard.activeSeason")</a>
                            }
                        </div>
                        <p class="card-text text-muted small mb-0">@Lang.Get("common.owner"): @vault.OwnerDisplayName</p>
                    </div>
                    <div class="card-footer border-0 pt-0 pb-3 px-3">
                        <a href="/vaults/@vault.Id" class="btn btn-outline-primary btn-sm w-100">@Lang.Get("dashboard.open") →</a>
                    </div>
                </div>
            </div>
        }
    </div>
}

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger mt-3">@errorMessage</div>
}
