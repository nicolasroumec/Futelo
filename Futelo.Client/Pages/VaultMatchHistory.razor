@page "/vaults/{id:int}/matches"
@attribute [Authorize]

<PageTitle>@Lang.Get("vault.matchHistory") - Futelo</PageTitle>

@if (isLoading)
{
    <div class="skeleton-block mb-4" style="width:140px;height:1.75rem"></div>
    <div class="recent-matches mb-4">
        @for (int i = 0; i < 10; i++)
        {
            <div class="recent-match-row">
                <div class="skeleton-block mb-1" style="height:.65rem;width:45%"></div>
                <div class="recent-match-body">
                    <div class="skeleton-block" style="height:.85rem;width:90%"></div>
                    <div class="skeleton-block" style="height:.85rem;width:60px"></div>
                    <div class="skeleton-block" style="height:.85rem;width:90%"></div>
                </div>
            </div>
        }
    </div>
}
else if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}
else
{
    <div class="d-flex align-items-center gap-3 mb-4">
        <a href="/vaults/@Id" class="btn btn-outline-secondary btn-sm">@Lang.Get("common.back")</a>
        <h3 class="mb-0">@Lang.Get("vault.matchHistory")</h3>
    </div>

    @if (history.TotalCount == 0)
    {
        <p class="empty-state">@Lang.Get("stats.noMatches")</p>
    }
    else
    {
        <div class="recent-matches mb-3">
            @foreach (var m in history.Items)
            {
                <div class="recent-match-row">
                    <span class="recent-match-competition text-muted small">@m.SeasonName · @m.CompetitionName</span>
                    <div class="recent-match-body">
                        <span class="recent-match-player text-end">@m.HomePlayerName@(m.HomeTeamName is not null ? $" ({m.HomeTeamName})" : "")</span>
                        <span class="recent-match-score fw-bold">@MatchScore(m)</span>
                        <span class="recent-match-player">@m.AwayPlayerName@(m.AwayTeamName is not null ? $" ({m.AwayTeamName})" : "")</span>
                    </div>
                    @if (m.VideoGameName is not null)
                    {
                        <span class="recent-match-game text-muted small">@m.VideoGameName</span>
                    }
                </div>
            }
        </div>

        <div class="d-flex align-items-center gap-3">
            <button class="btn btn-outline-secondary btn-sm" disabled="@(currentPage <= 1)" @onclick="PrevPage">←</button>
            <span class="text-muted small">@Lang.Get("vault.matchHistoryPage") @currentPage / @history.TotalPages</span>
            <button class="btn btn-outline-secondary btn-sm" disabled="@(currentPage >= history.TotalPages)" @onclick="NextPage">→</button>
        </div>
    }
}
