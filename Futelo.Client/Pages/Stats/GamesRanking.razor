@page "/vaults/{vaultId:int}/games"
@attribute [Authorize]

<PageTitle>Games Ranking - Futelo</PageTitle>

@if (isLoading)
{
    <SkeletonTable Columns="8" Rows="5" />
}
else
{
    <div class="d-flex align-items-center gap-3 mb-4">
        <a href="/vaults/@VaultId" class="btn btn-outline-secondary btn-sm">@Lang.Get("common.back")</a>
        <h3 class="mb-0">@Lang.Get("stats.gamesRanking")</h3>
    </div>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger mb-3">@errorMessage</div>
    }
    else if (games.Count == 0)
    {
        <p class="empty-state">@Lang.Get("stats.noGamesMatches")</p>
    }
    else
    {
        @foreach (var game in games)
        {
            <h5 class="mt-4">@game.VideoGameName</h5>
            <div class="table-responsive mb-3" style="max-width:600px">
                <table class="table table-sm table-bordered align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th>#</th>
                            <th>@Lang.Get("stats.player")</th>
                            <th>@Lang.Get("stats.played")</th>
                            <th>@Lang.Get("stats.wins")</th>
                            <th>@Lang.Get("stats.draws")</th>
                            <th>@Lang.Get("stats.losses")</th>
                            <th>@Lang.Get("league.goalsFor")</th>
                            <th>@Lang.Get("league.goalsAgainst")</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in game.Players)
                        {
                            <tr>
                                <td>@p.Position</td>
                                <td>
                                    <a href="/vaults/@VaultId/players/@p.PlayerId" class="text-decoration-none">
                                        @p.DisplayName
                                    </a>
                                </td>
                                <td>@p.Played</td>
                                <td>@p.Won</td>
                                <td>@p.Drawn</td>
                                <td>@p.Lost</td>
                                <td>@p.GoalsFor</td>
                                <td>@p.GoalsAgainst</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    }
}
