@page "/vaults/{vaultId:int}/players/{playerId}"
@inherits LocalizedComponentBase
@attribute [Authorize]

<PageTitle>@(stats?.DisplayName ?? "Player") - Futelo</PageTitle>

@if (isLoading)
{
    <div class="d-flex align-items-center gap-3 mb-4">
        <div class="skeleton-block" style="width:3.5rem;height:2rem"></div>
        <div class="skeleton-block" style="width:160px;height:1.75rem"></div>
        <div class="skeleton-block" style="width:6rem;height:1.5rem;border-radius:1rem"></div>
    </div>
    <div class="skeleton-block mb-2" style="width:50px;height:1rem"></div>
    <SkeletonTable Rows="1" Columns="7" />
    <div class="d-flex gap-1 mb-4">
        <div class="skeleton-block" style="width:2rem;height:1.5rem;border-radius:1rem"></div>
        <div class="skeleton-block" style="width:2rem;height:1.5rem;border-radius:1rem"></div>
        <div class="skeleton-block" style="width:2rem;height:1.5rem;border-radius:1rem"></div>
        <div class="skeleton-block" style="width:2rem;height:1.5rem;border-radius:1rem"></div>
        <div class="skeleton-block" style="width:2rem;height:1.5rem;border-radius:1rem"></div>
    </div>
    <div class="d-flex gap-4 mb-4">
        <div>
            <div class="skeleton-block mb-1" style="width:90px;height:.6rem"></div>
            <div class="skeleton-block" style="width:4rem;height:1.75rem;border-radius:1rem"></div>
        </div>
        <div>
            <div class="skeleton-block mb-1" style="width:90px;height:.6rem"></div>
            <div class="skeleton-block" style="width:4rem;height:1.75rem;border-radius:1rem"></div>
        </div>
        <div>
            <div class="skeleton-block mb-1" style="width:90px;height:.6rem"></div>
            <div class="skeleton-block" style="width:4rem;height:1.75rem;border-radius:1rem"></div>
        </div>
    </div>
    <div class="skeleton-block mb-2" style="width:90px;height:1rem"></div>
    <div class="skeleton-block" style="max-width:560px;height:160px"></div>
}
else if (stats == null)
{
    <p class="text-danger">@Lang.Get("player.notFound")</p>
}
else
{
    <div class="d-flex align-items-center gap-3 mb-4">
        <a href="/vaults/@VaultId" class="btn btn-outline-secondary btn-sm">@Lang.Get("common.back")</a>
        <div class="d-flex flex-column align-items-center" style="gap:4px">
            @if (isCurrentUser)
            {
                <ImageUpload Width="128" Height="128" DisplaySize="56"
                             ExistingImageUrl="@avatarUrl"
                             OnImageReady="HandleAvatarUpload" />
                <button class="btn btn-link btn-sm text-danger p-0 lh-1"
                        style="font-size:.7rem"
                        @onclick="HandleDeleteAvatar"
                        disabled="@isUploadingAvatar">
                    @Lang.Get("avatar.delete")
                </button>
            }
            else
            {
                <PlayerAvatar Name="@stats.DisplayName" Size="56" AvatarUrl="@Avatars.UrlFor(PlayerId)" />
            }
        </div>
        <div>
            <h3 class="mb-0">@stats.DisplayName</h3>
            <div class="d-flex align-items-baseline gap-2">
                <span class="elo-hero">@_elo</span>
                <span class="text-muted fw-semibold text-uppercase elo-hero__label">ELO</span>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger mb-3">@errorMessage</div>
    }

    <div class="row g-4">
        @* LEFT — Stats, form, streaks, titles *@
        <div class="col-lg-5">
            <h5>@Lang.Get("player.stats")</h5>
            <div class="table-responsive mb-2">
                <table class="table table-sm table-bordered align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th>@Lang.Get("stats.played")</th>
                            <th>@Lang.Get("stats.wins")</th>
                            <th>@Lang.Get("stats.draws")</th>
                            <th>@Lang.Get("stats.losses")</th>
                            <th>@Lang.Get("league.goalsFor")</th>
                            <th>@Lang.Get("league.goalsAgainst")</th>
                            <th>@Lang.Get("league.goalDiff")</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>@_played</td>
                            <td>@_won</td>
                            <td>@_drawn</td>
                            <td>@_lost</td>
                            <td>@_gf</td>
                            <td>@_ga</td>
                            <td>@(stats.GoalDifference > 0 ? $"+{stats.GoalDifference}" : stats.GoalDifference.ToString())</td>
                        </tr>
                    </tbody>
                </table>
            </div>

            @if (stats.Played > 0)
            {
                var winRate = stats.Won * 100 / stats.Played;
                <div class="mb-3">
                    <div class="d-flex justify-content-between mb-1">
                        <span class="small text-muted">@Lang.Get("player.winRate")</span>
                        <span class="small fw-semibold">@winRate%</span>
                    </div>
                    <div class="win-rate-track">
                        <div class="win-rate-fill" style="--wr:@winRate%"></div>
                    </div>
                </div>
            }

            @if (recentForm.Count > 0)
            {
                <div class="mb-4">
                    <div class="text-muted small mb-1">@Lang.Get("player.recentForm")</div>
                    <div class="d-flex gap-1">
                        @for (int i = 0; i < recentForm.Count; i++)
                        {
                            var entry = recentForm[i];
                            <span class="form-block @FormBadgeClass(entry.Result)"
                                  style="animation-delay:@(i * 0.06)s"
                                  title="@entry.OpponentDisplayName @entry.GoalsFor-@entry.GoalsAgainst">
                                @FormBadgeLabel(entry.Result)
                            </span>
                        }
                    </div>
                </div>
            }

            <div class="d-flex gap-4 mb-4">
                <div>
                    <div class="text-muted small mb-1">@Lang.Get("player.currentStreak")</div>
                    <span class="badge @StreakBadgeClass() fs-6">@StreakLabel()</span>
                </div>
                <div>
                    <div class="text-muted small mb-1">@Lang.Get("stats.bestWinStreak")</div>
                    <span class="badge bg-success fs-6">@stats.BestWinStreak W</span>
                </div>
                <div>
                    <div class="text-muted small mb-1">@Lang.Get("stats.bestUnbeatenRun")</div>
                    <span class="badge bg-primary fs-6">@stats.BestUnbeatenStreak</span>
                </div>
            </div>

            @if (stats.Titles.Count > 0)
            {
                <div class="mb-4">
                    <div class="text-muted small mb-2">@Lang.Get("player.titles") (@stats.Titles.Count)</div>
                    <div class="d-flex flex-wrap gap-2 mb-2">
                        @foreach (var comp in new[] { "League", "Cup", "SuperCup" })
                        {
                            var count = stats.Titles.Count(t => t.Competition == comp);
                            if (count == 0) continue;
                            var isActive = selectedTitleCompetition == comp;
                            <button class="title-chip title-chip--@comp.ToLower() @(isActive ? "title-chip--active" : "")"
                                    @onclick="() => selectedTitleCompetition = isActive ? null : comp">
                                @TitleIcon(comp) @Lang.Get(TitleI18nKey(comp)) ×@count
                            </button>
                        }
                    </div>

                    @if (selectedTitleCompetition != null)
                    {
                        <div class="title-detail">
                            @foreach (var t in stats.Titles.Where(t => t.Competition == selectedTitleCompetition).OrderByDescending(t => t.Year))
                            {
                                <div class="title-detail__row">
                                    <span class="title-detail__year">@t.Year</span>
                                    <span class="title-detail__season">@t.SeasonName</span>
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        </div>

        @* RIGHT — Records, ELO chart *@
        <div class="col-lg-7">
            @if (records != null && (records.BestWin != null || records.WorstDefeat != null || records.PeakElo > 0 || records.LongestTop1Reign > 0))
            {
                <h5 class="mt-2">@Lang.Get("player.records")</h5>
                <div class="records-grid mb-4">
                    @if (records.BestWin != null)
                    {
                        <div class="record-card record-card--win">
                            <div class="record-card__label">@Lang.Get("player.bestWin")</div>
                            <div class="record-card__value">@RecordMatchLabel(records.BestWin)</div>
                        </div>
                    }
                    @if (records.WorstDefeat != null)
                    {
                        <div class="record-card record-card--loss">
                            <div class="record-card__label">@Lang.Get("player.worstDefeat")</div>
                            <div class="record-card__value">@RecordMatchLabel(records.WorstDefeat)</div>
                        </div>
                    }
                    @if (records.PeakElo > 0)
                    {
                        <div class="record-card">
                            <div class="record-card__label">@Lang.Get("player.peakElo")</div>
                            <div class="record-card__value">@records.PeakElo</div>
                        </div>
                    }
                    @if (records.BestEloGain > 0)
                    {
                        <div class="record-card">
                            <div class="record-card__label">@Lang.Get("player.bestEloGain")</div>
                            <div class="record-card__value">+@records.BestEloGain</div>
                        </div>
                    }
                    @if (records.LongestTop1Reign > 0)
                    {
                        <div class="record-card">
                            <div class="record-card__label">@Lang.Get("player.longestTop1Reign")</div>
                            <div class="record-card__value">@records.LongestTop1Reign</div>
                        </div>
                    }
                    @if (records.TotalMatchesAtTop1 > 0)
                    {
                        <div class="record-card">
                            <div class="record-card__label">@Lang.Get("player.totalMatchesAtTop1")</div>
                            <div class="record-card__value">@records.TotalMatchesAtTop1</div>
                        </div>
                    }
                </div>
            }

            @if (globalEloHistory != null)
            {
                <h5>@Lang.Get("player.eloHistory")</h5>
                <div class="d-flex gap-1 mb-2 flex-wrap">
                    <button class="btn btn-sm @(competitionFilter == null ? "btn-primary" : "btn-outline-secondary")" @onclick='() => SetFilter(null)'>@Lang.Get("common.all")</button>
                    <button class="btn btn-sm @(competitionFilter == "League" ? "btn-primary" : "btn-outline-secondary")" @onclick='() => SetFilter("League")'>@Lang.Get("createSeason.league")</button>
                    <button class="btn btn-sm @(competitionFilter == "Cup" ? "btn-primary" : "btn-outline-secondary")" @onclick='() => SetFilter("Cup")'>@Lang.Get("createSeason.cup")</button>
                    <button class="btn btn-sm @(competitionFilter == "SuperCup" ? "btn-primary" : "btn-outline-secondary")" @onclick='() => SetFilter("SuperCup")'>@Lang.Get("createSeason.superCup")</button>
                </div>
                @if (globalEloHistory.Points.Count > 0)
                {
                    <div class="mb-4">
                        <canvas id="global-elo-chart"></canvas>
                    </div>
                }
                else
                {
                    <p class="text-muted small mb-4">@Lang.Get("stats.noMatches")</p>
                }
            }
        </div>
    </div>

    @* FULL WIDTH — Achievements *@
    <div class="mb-4">
        <h5>@Lang.Get("player.achievements") <span class="text-muted fw-normal fs-6">(@achievements.Count / @AchievementMeta.All.Count)</span></h5>
        @foreach (var group in AchievementMeta.All.GroupBy(kvp => AchievementMeta.GetCategory(kvp.Key)))
        {
            <div class="mb-3">
                <div class="achievement-category-label">@group.Key</div>
                <div class="d-flex flex-wrap gap-2">
                    @foreach (var kvp in group)
                    {
                        var unlocked = achievements.FirstOrDefault(a => a.Type == kvp.Key);
                        <div class="achievement-badge @(unlocked == null ? "achievement-badge--locked" : "")"
                             title="@AchievementMeta.GetDescription(kvp.Key)">
                            <span class="achievement-badge__icon">@AchievementMeta.GetIcon(kvp.Key)</span>
                            <div class="achievement-badge__text">
                                <span class="achievement-badge__name">@AchievementMeta.GetName(kvp.Key)</span>
                                @if (unlocked != null)
                                {
                                    <span class="achievement-badge__date">@unlocked.UnlockedAt.ToString("dd/MM/yy")</span>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    </div>

    @* FULL WIDTH — Top teams, game stats, recent matches *@
    @if (stats.TopTeams.Count > 0)
    {
        <h5>@Lang.Get("player.topTeams")</h5>
        <div class="table-responsive mb-4">
            <table class="table table-sm table-bordered align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>@Lang.Get("stats.team")</th>
                        <th>@Lang.Get("stats.played")</th>
                        <th>@Lang.Get("stats.wins")</th>
                        <th>@Lang.Get("stats.draws")</th>
                        <th>@Lang.Get("stats.losses")</th>
                        <th>@Lang.Get("league.goalsFor")</th>
                        <th>@Lang.Get("league.goalsAgainst")</th>
                        <th>@Lang.Get("league.goalDiff")</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var t in stats.TopTeams)
                    {
                        <tr>
                            <td>@t.TeamName</td>
                            <td>@t.TimesUsed</td>
                            <td>@t.Won</td>
                            <td>@t.Drawn</td>
                            <td>@t.Lost</td>
                            <td>@t.GoalsFor</td>
                            <td>@t.GoalsAgainst</td>
                            <td>@(t.GoalDifference > 0 ? $"+{t.GoalDifference}" : t.GoalDifference.ToString())</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    @if (stats.GameStats.Count > 0)
    {
        <h5>@Lang.Get("player.performance")</h5>
        <div class="table-responsive mb-4">
            <table class="table table-sm table-bordered align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>@Lang.Get("stats.game")</th>
                        <th>@Lang.Get("stats.played")</th>
                        <th>@Lang.Get("stats.wins")</th>
                        <th>@Lang.Get("stats.draws")</th>
                        <th>@Lang.Get("stats.losses")</th>
                        <th>@Lang.Get("league.goalsFor")</th>
                        <th>@Lang.Get("league.goalsAgainst")</th>
                        <th>@Lang.Get("league.goalDiff")</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var g in stats.GameStats)
                    {
                        <tr>
                            <td>@g.VideoGameName</td>
                            <td>@g.Played</td>
                            <td>@g.Won</td>
                            <td>@g.Drawn</td>
                            <td>@g.Lost</td>
                            <td>@g.GoalsFor</td>
                            <td>@g.GoalsAgainst</td>
                            <td>@(g.GoalDifference > 0 ? $"+{g.GoalDifference}" : g.GoalDifference.ToString())</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    <div class="d-flex align-items-center gap-3 mt-4 mb-2">
        <h5 class="mb-0">@Lang.Get("vault.recentMatches")</h5>
        <a href="/vaults/@VaultId/players/@PlayerId/matches" class="btn btn-outline-secondary btn-sm">@Lang.Get("vault.fullHistory")</a>
    </div>
    @if (recentMatches.Count == 0)
    {
        <EmptyState Message="@Lang.Get("stats.noMatches")" />
    }
    else
    {
        <div class="recent-matches mb-4">
            @foreach (var m in recentMatches)
            {
                <div class="recent-match-row">
                    <span class="recent-match-competition text-muted small">@m.SeasonName · @m.CompetitionName</span>
                    <MatchDisplay
                        HomePlayerId="@m.HomePlayerId"
                        AwayPlayerId="@m.AwayPlayerId"
                        HomeTeamId="@m.HomeTeamId"
                        AwayTeamId="@m.AwayTeamId"
                        HomePlayerName="@m.HomePlayerName"
                        AwayPlayerName="@m.AwayPlayerName"
                        HomeTeamName="@m.HomeTeamName"
                        AwayTeamName="@m.AwayTeamName"
                        VideoGameName="@m.VideoGameName"
                        HomeScore="@m.HomeScore"
                        AwayScore="@m.AwayScore"
                        IsPlayed="true"
                        WonOnPenaltiesId="@m.WonOnPenaltiesId"
                        HomePenaltyScore="@m.HomePenaltyScore"
                        AwayPenaltyScore="@m.AwayPenaltyScore" />
                </div>
            }
        </div>
    }

    @if (opponents.Count > 0)
    {
        <h5>@Lang.Get("headToHead.title")</h5>
        <div class="d-flex align-items-center gap-2" style="max-width:360px">
            <select class="form-select form-select-sm" @bind="selectedOpponentId">
                @foreach (var p in opponents)
                {
                    <option value="@p.PlayerId">@p.DisplayName</option>
                }
            </select>
            <button class="btn btn-outline-primary btn-sm" @onclick="NavigateToH2H">@Lang.Get("player.compare")</button>
        </div>
    }
}
