@inherits LocalizedComponentBase

<div class="mb-3" style="max-width:420px">
    <label class="form-label fw-semibold">@Lang.Get("season.players")</label>
    @foreach (var vp in VaultPlayers)
    {
        <div class="form-check">
            <input class="form-check-input" type="checkbox" id="pm_@vp.PlayerId"
                   checked="@SelectedPlayerIds.Contains(vp.PlayerId)"
                   @onchange="e => Toggle(vp.PlayerId, (bool)e.Value!)" />
            <label class="form-check-label" for="pm_@vp.PlayerId">@vp.DisplayName</label>
        </div>
    }
</div>
