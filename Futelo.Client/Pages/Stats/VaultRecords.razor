@page "/vaults/{vaultId:int}/records"
@attribute [Authorize]

<PageTitle>Records - Futelo</PageTitle>

@if (isLoading)
{
    <p>Loading...</p>
}
else
{
    <div class="d-flex align-items-center gap-3 mb-4">
        <a href="/vaults/@VaultId" class="btn btn-outline-secondary btn-sm">Back</a>
        <h3 class="mb-0">All-Time Records</h3>
    </div>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger mb-3">@errorMessage</div>
    }
    else if (records?.BestWinStreak == null && records?.BestUnbeatenStreak == null)
    {
        <p class="empty-state">No matches played yet.</p>
    }
    else
    {
        <div class="d-flex flex-column gap-3" style="max-width:420px">
            @if (records!.BestWinStreak != null)
            {
                <div class="card">
                    <div class="card-body">
                        <div class="text-muted small mb-1">Best Win Streak</div>
                        <div class="d-flex align-items-center justify-content-between">
                            <a href="/vaults/@VaultId/players/@records.BestWinStreak.PlayerId"
                               class="fw-semibold text-decoration-none fs-5">
                                @records.BestWinStreak.DisplayName
                            </a>
                            <span class="badge bg-success fs-5">@records.BestWinStreak.Value W</span>
                        </div>
                    </div>
                </div>
            }
            @if (records!.BestUnbeatenStreak != null)
            {
                <div class="card">
                    <div class="card-body">
                        <div class="text-muted small mb-1">Best Unbeaten Run</div>
                        <div class="d-flex align-items-center justify-content-between">
                            <a href="/vaults/@VaultId/players/@records.BestUnbeatenStreak.PlayerId"
                               class="fw-semibold text-decoration-none fs-5">
                                @records.BestUnbeatenStreak.DisplayName
                            </a>
                            <span class="badge bg-primary fs-5">@records.BestUnbeatenStreak.Value</span>
                        </div>
                    </div>
                </div>
            }
            @if (topScoringMatch != null)
            {
                <div class="card">
                    <div class="card-body">
                        <div class="text-muted small mb-1">Top Scoring Match</div>
                        <div class="d-flex align-items-center justify-content-between">
                            <span class="fw-semibold fs-5">
                                @topScoringMatch.HomePlayerDisplayName @topScoringMatch.HomeScore – @topScoringMatch.AwayScore @topScoringMatch.AwayPlayerDisplayName
                            </span>
                            <span class="badge bg-warning text-dark fs-5">@topScoringMatch.TotalGoals goals</span>
                        </div>
                        @if (!string.IsNullOrEmpty(topScoringMatch.SeasonName))
                        {
                            <div class="text-muted small mt-1">@topScoringMatch.SeasonName</div>
                        }
                    </div>
                </div>
            }
        </div>
    }
}
