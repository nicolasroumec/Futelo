@page "/leagues/{id:int}"
@inherits LocalizedComponentBase
@attribute [Authorize]

<PageTitle>@(league?.Name ?? "League") - Futelo</PageTitle>

@if (isLoading)
{
    <div class="d-flex align-items-center gap-3 mb-4">
        <div class="skeleton-block" style="width:3.5rem;height:2rem"></div>
        <div class="skeleton-block" style="width:160px;height:1.75rem"></div>
        <div class="skeleton-block" style="width:4.5rem;height:1.5rem;border-radius:1rem"></div>
    </div>
    <div class="skeleton-block mb-2" style="width:80px;height:1rem"></div>
    <SkeletonTable Rows="5" Columns="10" />
    <div class="skeleton-block mb-2 mt-4" style="width:60px;height:1rem"></div>
    <div class="skeleton-block mb-2" style="width:90px;height:.65rem"></div>
    <div class="card mb-2" style="max-width:480px">
        <div class="card-body py-2 px-3">
            <div class="d-flex justify-content-between align-items-center">
                <div class="skeleton-block" style="width:30%;height:.8rem"></div>
                <div class="skeleton-block" style="width:15%;height:.8rem"></div>
                <div class="skeleton-block" style="width:30%;height:.8rem"></div>
            </div>
        </div>
    </div>
    <div class="card mb-2" style="max-width:480px">
        <div class="card-body py-2 px-3">
            <div class="d-flex justify-content-between align-items-center">
                <div class="skeleton-block" style="width:30%;height:.8rem"></div>
                <div class="skeleton-block" style="width:15%;height:.8rem"></div>
                <div class="skeleton-block" style="width:30%;height:.8rem"></div>
            </div>
        </div>
    </div>
}
else if (league == null)
{
    <EmptyState Message="@Lang.Get("league.notFound")" />
}
else
{
    <nav aria-label="breadcrumb" class="mb-2">
        <ol class="breadcrumb mb-0 small">
            <li class="breadcrumb-item">
                <a href="/dashboard" class="breadcrumb-link">@Lang.Get("nav.dashboard")</a>
            </li>
            <li class="breadcrumb-item">
                <a href="/vaults/@league.VaultId" class="breadcrumb-link">@league.VaultName</a>
            </li>
            <li class="breadcrumb-item">
                <a href="/seasons/@league.SeasonId" class="breadcrumb-link">@league.SeasonName</a>
            </li>
            <li class="breadcrumb-item active fw-semibold" aria-current="page">@league.Name</li>
        </ol>
    </nav>
    <div class="d-flex align-items-center gap-2 flex-wrap mb-3">
        <h3 class="mb-0 me-1">@league.Name</h3>
        <span class="badge @BadgeHelper.StatusBadgeClass(league.Status)">@Lang.Get("competition.status." + league.Status.ToLower())</span>
        @if (league.IsHomeAndAway)
        {
            <span class="badge bg-info text-dark">@Lang.Get("season.homeAndAway")</span>
        }
        @if (league.Status == "Finished" && league.ChampionName != null)
        {
            <span class="badge bg-warning text-dark">🏆 @league.ChampionName</span>
        }
    </div>

    @if (editingDates)
    {
        <div class="d-flex align-items-center gap-2 mb-3 flex-wrap">
            <input type="date" class="form-control form-control-sm" style="width:160px" @bind="editStartDate" />
            <span class="text-muted">→</span>
            <input type="date" class="form-control form-control-sm" style="width:160px" @bind="editEndDate" />
            <button class="btn btn-sm btn-primary" disabled="@isSavingDates" @onclick="HandlePatchDates">
                @if (isSavingDates)
                {
                    <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                }
                @(isSavingDates ? Lang.Get("common.saving") : Lang.Get("common.save"))
            </button>
            <button class="btn btn-sm btn-outline-secondary" @onclick="() => editingDates = false">@Lang.Get("common.cancel")</button>
        </div>
    }
    else
    {
        <div class="d-flex align-items-center gap-2 mb-3 text-muted small">
            <span>📅 @(league.StartDate.HasValue ? league.StartDate.Value.ToString("dd MMM yyyy") : "—") → @(league.EndDate.HasValue ? league.EndDate.Value.ToString("dd MMM yyyy") : "—")</span>
            @if (league.CanEdit)
            {
                <button class="btn btn-link btn-sm p-0 text-muted" @onclick="BeginEditDates">✏️</button>
            }
        </div>
    }

    <div class="text-muted small mb-3 d-flex gap-3">
        <span>@Lang.Get("season.tiebreaker"): <strong>@TiebreakerSummary</strong> · <em>@Lang.Get(FinalTiebreakerKey)</em></span>
        @if (league.IsHomeAndAway)
        {
            <span>· @Lang.Get("season.homeAndAway")</span>
        }
    </div>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger mb-3">@errorMessage</div>
    }

    @if (league.Status == "NotStarted")
    {
        <div class="d-flex gap-2 mb-4">
            <button class="btn btn-success" disabled="@isWorking" @onclick="HandleStart">
                @if (isWorking)
                {
                    <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                }
                @(isWorking ? Lang.Get("league.generating") : Lang.Get("league.generateFixture"))
            </button>
            @if (league.CanEdit)
            {
                <button class="btn btn-outline-secondary" disabled="@isWorking" @onclick="HandleStartManual">
                    @if (isWorking)
                    {
                        <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                    }
                    @Lang.Get("league.startManual")
                </button>
            }
        </div>
    }
    else
    {
        <div class="row g-4">
            @* LEFT — Standings *@
            <div class="col-lg-5">
                <h5 class="mt-2">@Lang.Get("league.standings")</h5>
                @if (league.Standings.Count == 0)
                {
                    <EmptyState Title="@Lang.Get("league.noResultsTitle")"
                                Message="@Lang.Get("league.noResults")">
                        <Icon>⚽</Icon>
                    </EmptyState>
                }
                else
                {
                    <div class="table-responsive mb-3">
                        <table class="table table-sm table-bordered align-middle">
                            <thead class="table-dark">
                                <tr>
                                    <th>#</th>
                                    <th>@Lang.Get("stats.player")</th>
                                    <th>@Lang.Get("stats.played")</th>
                                    <th>@Lang.Get("stats.wins")</th>
                                    <th>@Lang.Get("stats.draws")</th>
                                    <th>@Lang.Get("stats.losses")</th>
                                    <th>@Lang.Get("league.goalsFor")</th>
                                    <th>@Lang.Get("league.goalsAgainst")</th>
                                    <th>@Lang.Get("league.goalDiff")</th>
                                    <th>@Lang.Get("league.points")</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{ int pos = 1; }
                                @foreach (var row in league.Standings)
                                {
                                    <tr class="@(row.PlayerId == currentUserId ? "standings-me" : "")" @key="row.PlayerId">
                                        <td>@pos</td>
                                        <td>@row.DisplayName</td>
                                        <td>@row.Played</td>
                                        <td>@row.Won</td>
                                        <td>@row.Drawn</td>
                                        <td>@row.Lost</td>
                                        <td>@row.GoalsFor</td>
                                        <td>@row.GoalsAgainst</td>
                                        <td>@(row.GoalDifference > 0 ? $"+{row.GoalDifference}" : row.GoalDifference.ToString())</td>
                                        <td><strong>@row.Points</strong></td>
                                    </tr>
                                    pos++;
                                }
                            </tbody>
                        </table>
                    </div>
                }

                @if (PendingByPlayer.Count > 0)
                {
                    <div class="pending-summary mb-3">
                        <span class="pending-summary__label">@Lang.Get("league.pendingByPlayer"):</span>
                        @foreach (var (name, count) in PendingByPlayer)
                        {
                            <span class="pending-summary__chip" @key="name">@name <strong>@count</strong></span>
                        }
                    </div>
                }
            </div>

            @* RIGHT — Fixture *@
            <div class="col-lg-7">
                <h5 class="mt-2">@Lang.Get("league.fixture")</h5>

                @if (Matchdays.Count > 1)
                {
                    <div class="matchday-tabs mb-3">
                        @foreach (var day in Matchdays)
                        {
                            var hasPending = league.Matches.Any(m => m.Matchday == day && m.Status == "Pending");
                            <button @key="day" class="matchday-tab @(selectedMatchday == day ? "matchday-tab--active" : "") @(hasPending ? "matchday-tab--has-pending" : "")"
                                    @onclick="() => { selectedMatchday = day; recordingMatchId = null; }">
                                @day
                                @if (hasPending)
                                {
                                    <span class="matchday-tab__dot"></span>
                                }
                            </button>
                        }
                    </div>
                }

                <div class="mb-3">
                    @foreach (var match in league.Matches.Where(m => m.Matchday == selectedMatchday))
                    {
                        var isEditable = league.CanEdit && league.Status != "NotStarted";
                        <div @key="match.Id" class="match-card @(match.Status == "Played" ? "match-card--played" : "match-card--pending") @(isEditable ? "match-card--editable" : "") mb-2"
                             @onclick="() => HandleMatchClick(match.Id)">
                            <div class="card-body py-2 px-3">
                                <MatchDisplay
                                    HomePlayerName="@match.HomePlayerName"
                                    AwayPlayerName="@match.AwayPlayerName"
                                    HomeTeamName="@match.HomeTeamName"
                                    AwayTeamName="@match.AwayTeamName"
                                    VideoGameName="@match.VideoGameName"
                                    HomeScore="@match.HomeScore"
                                    AwayScore="@match.AwayScore"
                                    IsPlayed="@(match.Status == "Played")" />
                                @if (match.ScheduledDate.HasValue && match.Status != "Played")
                                {
                                    <div class="text-muted small mt-1">📅 @match.ScheduledDate.Value.ToString("dd MMM yyyy")</div>
                                }

                                @if (recordingMatchId == match.Id)
                                {
                                    <div @onclick:stopPropagation="true" @onclick="() => {}">
                                        <MatchResultForm
                                            HomePlayerId="@match.HomePlayerId"
                                            HomePlayerName="@match.HomePlayerName"
                                            AwayPlayerId="@match.AwayPlayerId"
                                            AwayPlayerName="@match.AwayPlayerName"
                                            IsSaving="isRecording"
                                            OnSave="HandleRecordResult"
                                            OnCancel="() => recordingMatchId = null" />
                                    </div>
                                }
                                @if (lastResultMatchId == match.Id && lastEloResult != null)
                                {
                                    <EloChangeSummary
                                        HomeName="@lastEloResult.Home.DisplayName"
                                        HomeEloChange="@lastEloResult.Home.EloChange"
                                        HomeEloBefore="@lastEloResult.Home.EloBefore"
                                        HomeEloAfter="@lastEloResult.Home.EloAfter"
                                        HomeRankBefore="@lastEloResult.Home.RankBefore"
                                        HomeRankAfter="@lastEloResult.Home.RankAfter"
                                        AwayName="@lastEloResult.Away.DisplayName"
                                        AwayEloChange="@lastEloResult.Away.EloChange"
                                        AwayEloBefore="@lastEloResult.Away.EloBefore"
                                        AwayEloAfter="@lastEloResult.Away.EloAfter"
                                        AwayRankBefore="@lastEloResult.Away.RankBefore"
                                        AwayRankAfter="@lastEloResult.Away.RankAfter" />
                                }

                                <MatchEditPanel
                                    IsEditing="editingMatchId == match.Id"
                                    IsLastPlayed="match.IsLastPlayed"
                                    HomePlayerName="@match.HomePlayerName"
                                    AwayPlayerName="@match.AwayPlayerName"
                                    HomeTeamId="match.HomeTeamId"
                                    AwayTeamId="match.AwayTeamId"
                                    VideoGameId="match.VideoGameId"
                                    ScheduledDate="match.ScheduledDate"
                                    Teams="teams"
                                    VideoGames="videoGames"
                                    OnSave="HandlePatchMatch"
                                    OnCancel="() => editingMatchId = null"
                                    OnRequestCorrection="() => HandleRequestCorrection(match.Id)" />
                                @if (correctingMatchId == match.Id)
                                {
                                    <div @onclick:stopPropagation="true" @onclick="() => {}">
                                        <MatchResultForm
                                            HomePlayerId="@match.HomePlayerId"
                                            HomePlayerName="@match.HomePlayerName"
                                            AwayPlayerId="@match.AwayPlayerId"
                                            AwayPlayerName="@match.AwayPlayerName"
                                            InitialHomeScore="match.HomeScore"
                                            InitialAwayScore="match.AwayScore"
                                            IsSaving="isCorrecting"
                                            OnSave="HandleCorrectResult"
                                            OnCancel="() => correctingMatchId = null" />
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>

                @if (league.Status == "Active" && league.CanEdit)
                {
                    @if (addingMatch)
                    {
                        <div class="card mt-3 mb-2" style="border-color:rgba(34,197,94,.2);background:rgba(34,197,94,.03)">
                            <div class="card-body p-3">
                                <div class="row g-2 align-items-end">
                                    <div class="col-auto">
                                        <label class="form-label small mb-1">@Lang.Get("league.matchday")</label>
                                        <input type="number" class="form-control form-control-sm" style="max-width:80px" min="1" @bind="newMatchday" />
                                    </div>
                                    <div class="col-12 col-sm">
                                        <label class="form-label small mb-1">@Lang.Get("league.homePlayer")</label>
                                        <select class="form-select form-select-sm" @bind="newHomePlayerId">
                                            <option value="">@Lang.Get("common.select")</option>
                                            @foreach (var p in league.SeasonPlayers)
                                            {
                                                <option value="@p.Id">@p.DisplayName</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="col-12 col-sm">
                                        <label class="form-label small mb-1">@Lang.Get("league.awayPlayer")</label>
                                        <select class="form-select form-select-sm" @bind="newAwayPlayerId">
                                            <option value="">@Lang.Get("common.select")</option>
                                            @foreach (var p in league.SeasonPlayers)
                                            {
                                                <option value="@p.Id">@p.DisplayName</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="col-auto d-flex gap-2">
                                        <button class="btn btn-primary btn-sm" disabled="@isAddingMatch" @onclick="HandleAddMatch">
                                            @if (isAddingMatch)
                                            {
                                                <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                                            }
                                            @Lang.Get("league.addMatch")
                                        </button>
                                        <button class="btn btn-outline-secondary btn-sm" @onclick="() => addingMatch = false">
                                            @Lang.Get("common.cancel")
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <button class="btn btn-outline-primary btn-sm mt-2 mb-2" @onclick="BeginAddMatch">
                            + @Lang.Get("league.addMatch")
                        </button>
                    }
                }

                @if (league.Status == "Active" && league.Matches.All(m => m.Status == "Pending"))
                {
                    @if (!confirmReshuffle)
                    {
                        <button class="btn btn-outline-secondary btn-sm" @onclick="() => confirmReshuffle = true">
                            @Lang.Get("league.reshuffle")
                        </button>
                    }
                    else
                    {
                        <span class="d-flex align-items-center gap-2">
                            <small class="text-danger">@Lang.Get("league.reshuffleConfirm")</small>
                            <button class="btn btn-danger btn-sm" disabled="@isWorking" @onclick="HandleReshuffle">
                                @if (isWorking)
                                {
                                    <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                                }
                                @Lang.Get("common.confirmDelete")
                            </button>
                            <button class="btn btn-outline-secondary btn-sm" @onclick="() => confirmReshuffle = false">
                                @Lang.Get("common.cancel")
                            </button>
                        </span>
                    }
                }
            </div>
        </div>
    }
}
