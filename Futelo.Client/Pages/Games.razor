@page "/games"
@inherits LocalizedComponentBase
@attribute [Authorize]

<PageTitle>@Lang.Get("games.title") - Futelo</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3>@Lang.Get("games.title")</h3>
    <button class="btn btn-primary" @onclick="ShowCreateForm">@Lang.Get("games.newGame")</button>
</div>

@if (showForm)
{
    <div class="card card-form mb-4">
        <div class="card-body">
            <h5 class="card-title">@(editingId.HasValue ? Lang.Get("games.editGame") : Lang.Get("games.newGame"))</h5>
            <EditForm Model="formModel" OnValidSubmit="HandleSubmit">
                <DataAnnotationsValidator />
                <div class="mb-3">
                    <label class="form-label">@Lang.Get("common.name")</label>
                    <InputText class="form-control" @bind-Value="formModel.Name" />
                    <div class="invalid-feedback"><ValidationMessage For="() => formModel.Name" /></div>
                </div>
                @if (!string.IsNullOrEmpty(formError))
                {
                    <div class="alert alert-danger">@formError</div>
                }
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary" disabled="@isSubmitting">
                        @(isSubmitting ? Lang.Get("common.saving") : Lang.Get("common.save"))
                    </button>
                    <button type="button" class="btn btn-secondary" @onclick="CancelForm">@Lang.Get("common.cancel")</button>
                </div>
            </EditForm>
        </div>
    </div>
}

@if (isLoading)
{
    <SkeletonCards Count="6" Columns="3" />
}
else if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}
else if (games.Count == 0)
{
    <EmptyState Message="@Lang.Get("games.empty")" />
}
else
{
    <div class="row row-cols-1 row-cols-md-3 g-4">
        @foreach (var game in games)
        {
            <div class="col">
                <div class="card card-glass h-100">
                    <div class="card-body">
                        <h5 class="card-title mb-0">@game.Name</h5>
                    </div>
                    <div class="card-footer d-flex align-items-center gap-2">
                        <button class="btn btn-outline-secondary btn-sm" @onclick="() => EditGame(game)">@Lang.Get("common.edit")</button>
                        @if (confirmingDeleteId == game.Id)
                        {
                            <span class="text-muted small">@Lang.Get("common.confirmDelete")?</span>
                            <button class="btn btn-danger btn-sm" @onclick="() => DeleteGame(game.Id)" disabled="@isDeleting">@Lang.Get("common.yes")</button>
                            <button class="btn btn-outline-secondary btn-sm" @onclick="CancelDelete" disabled="@isDeleting">@Lang.Get("common.no")</button>
                        }
                        else
                        {
                            <button class="btn btn-outline-danger btn-sm" @onclick="() => StartDeleteGame(game.Id)">@Lang.Get("common.delete")</button>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}
