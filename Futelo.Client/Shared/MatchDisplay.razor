<div class="match-layout">
    <div class="match-card__player d-flex align-items-center gap-1 @(HomePlayerMuted ? "text-muted" : "")">
        @if (HomePlayerId != null)
        {
            <PlayerAvatar Name="@HomePlayerName" Size="22" AvatarUrl="@($"/api/users/{HomePlayerId}/avatar")" />
        }
        <span>@HomePlayerName</span>
    </div>
    @if (HasGame)
    {
        <span class="match-meta__item text-center fst-italic">@VideoGameName</span>
    }
    else if (IsPlayed)
    {
        <span class="match-card__score fw-bold text-center">@HomeScore – @AwayScore</span>
    }
    else
    {
        <span class="match-card__vs text-muted text-center">vs</span>
    }
    <div class="match-card__player d-flex align-items-center justify-content-end gap-1 @(AwayPlayerMuted ? "text-muted" : "")">
        <span>@AwayPlayerName</span>
        @if (AwayPlayerId != null)
        {
            <PlayerAvatar Name="@AwayPlayerName" Size="22" AvatarUrl="@($"/api/users/{AwayPlayerId}/avatar")" />
        }
    </div>
    @if (HasGame)
    {
        <span class="match-meta__item">@HomeTeamName</span>
        @if (IsPlayed)
        {
            <span class="match-card__score fw-bold text-center">
                @HomeScore – @AwayScore
                @if (WonOnPenaltiesId != null)
                {
                    <span class="text-muted small"> (@HomePenaltyScore–@AwayPenaltyScore pen)</span>
                }
            </span>
        }
        else
        {
            <span class="match-card__vs text-muted text-center">vs</span>
        }
        <span class="match-meta__item text-end">@AwayTeamName</span>
    }
    else if (HasTeams)
    {
        <span class="match-meta__item">@HomeTeamName</span>
        <span></span>
        <span class="match-meta__item text-end">@AwayTeamName</span>
    }
</div>
