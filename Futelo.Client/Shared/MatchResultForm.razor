@using Futelo.Client.Shared

<div class="match-result-form mt-2 border-top pt-3">

    <div class="d-flex justify-content-center align-items-end gap-3 mb-3">
        <div class="text-center">
            <label class="form-label form-label-sm fw-semibold mb-1 d-block">@HomePlayerName</label>
            <input type="number" min="0" class="form-control form-control-sm text-center fw-bold"
                   style="width:72px;font-size:1.2rem" @bind="homeScore" placeholder="0" />
        </div>
        <div class="pb-1 text-muted fw-bold fs-5">–</div>
        <div class="text-center">
            <label class="form-label form-label-sm fw-semibold mb-1 d-block">@AwayPlayerName</label>
            <input type="number" min="0" class="form-control form-control-sm text-center fw-bold"
                   style="width:72px;font-size:1.2rem" @bind="awayScore" placeholder="0" />
        </div>
    </div>

    @if (HasPenalties && ShowPenaltyFields)
    {
        <div class="p-2 rounded-2 mb-3" style="background:var(--color-surface-2)">
            <div class="small fw-semibold text-muted mb-2 text-uppercase"
                 style="font-size:.7rem;letter-spacing:.06em">@Lang.Get("cup.penalties")</div>
            <div class="d-flex justify-content-center align-items-end gap-3">
                <div class="text-center">
                    <label class="form-label form-label-sm mb-1">@HomePlayerName</label>
                    <input type="number" min="0" class="form-control form-control-sm text-center"
                           style="width:72px" @bind="homePenaltyScore" placeholder="0" />
                </div>
                <div class="pb-1 text-muted fw-bold">–</div>
                <div class="text-center">
                    <label class="form-label form-label-sm mb-1">@AwayPlayerName</label>
                    <input type="number" min="0" class="form-control form-control-sm text-center"
                           style="width:72px" @bind="awayPenaltyScore" placeholder="0" />
                </div>
            </div>
        </div>
    }

    @if (ShowPenaltyDrawWarning)
    {
        <div class="text-center text-warning small mb-2">@Lang.Get("cup.penalties.required")</div>
    }

    <div class="d-flex justify-content-center gap-2">
        <button class="btn btn-sm btn-success" disabled="@(IsSaving || !PenaltiesResolved)" @onclick="HandleSave">
            @if (IsSaving)
            {
                <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
            }
            @Lang.Get("common.save")
        </button>
        <button class="btn btn-sm btn-outline-secondary" @onclick="HandleCancel">
            @Lang.Get("common.cancel")
        </button>
    </div>
</div>
