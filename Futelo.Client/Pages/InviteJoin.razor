@page "/invite/join"
@inherits LocalizedComponentBase

<PageTitle>Join Vault - Futelo</PageTitle>

<div class="row justify-content-center mt-5">
    <div class="col-md-4 text-center">
        @if (isLoading)
        {
            <p>@Lang.Get("invitation.loading")</p>
        }
        else if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger">@errorMessage</div>
            <a href="/" class="btn btn-outline-secondary mt-2">@Lang.Get("invitation.goToHome")</a>
        }
        else if (preview is not null)
        {
            <div class="card p-4">
                <p class="text-muted mb-1">@Lang.Get("invitation.youreInvited")</p>
                <h3 class="mb-1">@preview.VaultName</h3>
                <p class="text-muted small mb-4">@Lang.Get("invitation.role"): @preview.Role &middot; @Lang.Get("invitation.expires") @preview.ExpiresAt.ToLocalTime().ToString("MMM d, yyyy")</p>
                <div class="d-flex flex-column gap-2">
                    <a href="@LoginUrl" class="btn btn-primary">@Lang.Get("invitation.loginToJoin")</a>
                    <a href="@RegisterUrl" class="btn btn-outline-primary">@Lang.Get("invitation.createAccountAndJoin")</a>
                </div>
            </div>
        }
    </div>
</div>
