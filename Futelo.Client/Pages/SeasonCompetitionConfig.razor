@using Futelo.Shared.Enums
@inherits LocalizedComponentBase

<div class="mb-3">
    <label class="form-label fw-semibold">@Lang.Get("season.competitions")</label>
    <div class="form-check">
        <input class="form-check-input" type="checkbox" id="chkLeague"
               @bind="Model.HasLeague" />
        <label class="form-check-label" for="chkLeague">@Lang.Get("createSeason.league")</label>
    </div>
    @if (Model.HasLeague)
    {
        <div class="ms-3 mb-2">
            <input type="text" class="form-control form-control-sm" style="max-width:220px"
                   placeholder="@Lang.Get("season.leagueNamePlaceholder")" @bind="Model.LeagueName" />
        </div>
        <div class="form-check ms-3">
            <input class="form-check-input" type="checkbox" id="chkLeagueH2H"
                   @bind="Model.LeagueIsHomeAndAway" />
            <label class="form-check-label" for="chkLeagueH2H">@Lang.Get("season.homeAndAway")</label>
        </div>
        <div class="ms-3 mt-2" style="max-width:260px">
            <label class="form-label form-label-sm mb-1">@Lang.Get("season.tiebreaker")</label>
            <select class="form-select form-select-sm" @bind="Model.LeagueTiebreakerRule">
                <option value="@TiebreakerRule.GoalDifference">@Lang.Get("season.tiebreaker.goalDifference")</option>
                <option value="@TiebreakerRule.HeadToHead">@Lang.Get("season.tiebreaker.headToHead")</option>
                <option value="@TiebreakerRule.HeadToHeadThenGoalDifference">@Lang.Get("season.tiebreaker.headToHeadThenGD")</option>
            </select>
        </div>
    }
    <div class="form-check">
        <input class="form-check-input" type="checkbox" id="chkCup"
               @bind="Model.HasCup" />
        <label class="form-check-label" for="chkCup">@Lang.Get("createSeason.cup")</label>
    </div>
    @if (Model.HasCup)
    {
        <div class="ms-3 mb-2">
            <input type="text" class="form-control form-control-sm" style="max-width:220px"
                   placeholder="@Lang.Get("season.cupNamePlaceholder")" @bind="Model.CupName" />
        </div>
    }
    <div class="form-check">
        <input class="form-check-input" type="checkbox" id="chkSuperCup"
               @bind="Model.HasSuperCup"
               disabled="@(!Model.HasLeague || !Model.HasCup)" />
        <label class="form-check-label" for="chkSuperCup">@Lang.Get("createSeason.superCup")</label>
    </div>
    @if (Model.HasSuperCup)
    {
        <div class="ms-3 mb-2">
            <input type="text" class="form-control form-control-sm" style="max-width:220px"
                   placeholder="@Lang.Get("season.superCupNamePlaceholder")" @bind="Model.SuperCupName" />
        </div>
    }
</div>
