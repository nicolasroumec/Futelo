@page "/invitations/{token}/accept"
@attribute [Authorize]

<PageTitle>Accept Invitation - Futelo</PageTitle>

<div class="row justify-content-center mt-5">
    <div class="col-md-4 text-center">
        @if (isLoading)
        {
            <p>Processing invitation...</p>
        }
        else if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger">@errorMessage</div>
            <a href="/dashboard" class="btn btn-outline-secondary mt-2">Go to Dashboard</a>
        }
        else
        {
            <div class="alert alert-success">You have joined the vault successfully!</div>
            <a href="/dashboard" class="btn btn-primary mt-2">Go to Dashboard</a>
        }
    </div>
</div>
