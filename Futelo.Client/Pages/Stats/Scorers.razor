@page "/vaults/{vaultId:int}/scorers"
@attribute [Authorize]

<PageTitle>Scorers - Futelo</PageTitle>

@if (isLoading)
{
    <p>Loading...</p>
}
else
{
    <div class="d-flex align-items-center gap-3 mb-4">
        <a href="/vaults/@VaultId" class="btn btn-outline-secondary btn-sm">Back</a>
        <h3 class="mb-0">Top Scorers</h3>
    </div>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger mb-3">@errorMessage</div>
    }
    else if (rows.Count == 0)
    {
        <p class="empty-state">No matches played yet.</p>
    }
    else
    {
        <div class="table-responsive" style="max-width:400px">
            <table class="table table-sm table-bordered align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Player</th>
                        <th>Goals</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in rows)
                    {
                        <tr>
                            <td>@row.Position</td>
                            <td>
                                <a href="/vaults/@VaultId/players/@row.PlayerId" class="text-decoration-none">
                                    @row.DisplayName
                                </a>
                            </td>
                            <td><strong>@row.Goals</strong></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}
