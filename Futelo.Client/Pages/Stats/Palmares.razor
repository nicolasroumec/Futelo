@page "/vaults/{vaultId:int}/palmares"
@attribute [Authorize]

<PageTitle>Palmarés - Futelo</PageTitle>

@if (isLoading)
{
    <SkeletonTable Columns="5" Rows="3" />
}
else
{
    <div class="d-flex align-items-center gap-3 mb-4">
        <a href="/vaults/@VaultId" class="btn btn-outline-secondary btn-sm">@Lang.Get("common.back")</a>
        <h3 class="mb-0">@Lang.Get("stats.palmares")</h3>
    </div>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger mb-3">@errorMessage</div>
    }
    else if (rows.Count == 0)
    {
        <p class="empty-state">@Lang.Get("stats.noFinishedSeasons")</p>
    }
    else
    {
        <div class="table-responsive" style="max-width:640px">
            <table class="table table-sm table-bordered align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>@Lang.Get("season.year")</th>
                        <th>@Lang.Get("stats.season")</th>
                        <th>@Lang.Get("createSeason.league")</th>
                        <th>@Lang.Get("createSeason.cup")</th>
                        <th>@Lang.Get("createSeason.superCup")</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in rows)
                    {
                        <tr>
                            <td>@row.Year</td>
                            <td>@row.SeasonName</td>
                            <td>@(row.LeagueChampion ?? "-")</td>
                            <td>@(row.CupChampion ?? "-")</td>
                            <td>@(row.SuperCupChampion ?? "-")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}
