@page "/vaults/{vaultId:int}/seasons/create"
@inherits LocalizedComponentBase
@attribute [Authorize]

<PageTitle>New Season - Futelo</PageTitle>

<div class="row justify-content-center mt-4">
    <div class="col-md-5">
        <div class="d-flex align-items-center gap-3 mb-4">
            <a href="/vaults/@VaultId" class="btn btn-outline-secondary btn-sm">@Lang.Get("common.back")</a>
            <h3 class="mb-0">@Lang.Get("createSeason.title")</h3>
        </div>

        <EditForm Model="model" OnValidSubmit="HandleCreate">
            <DataAnnotationsValidator />

            <div class="mb-3">
                <label class="form-label">@Lang.Get("common.name")</label>
                <InputText class="form-control" @bind-Value="model.Name" placeholder="e.g. Season 2026" />
                <div class="invalid-feedback"><ValidationMessage For="() => model.Name" /></div>
            </div>

            <div class="mb-3">
                <label class="form-label">@Lang.Get("season.year")</label>
                <InputNumber class="form-control" @bind-Value="model.Year" />
                <div class="invalid-feedback"><ValidationMessage For="() => model.Year" /></div>
            </div>

            <div class="mb-3">
                <label class="form-label">@Lang.Get("season.videoGame")</label>
                <InputSelect class="form-select" @bind-Value="model.VideoGameId">
                    <option value="">@Lang.Get("common.none")</option>
                    @foreach (var g in videoGames)
                    {
                        <option value="@g.Id">@g.Name</option>
                    }
                </InputSelect>
            </div>

            <div class="mb-3">
                <label class="form-label">@Lang.Get("season.startDate")</label>
                <InputDate class="form-control" @bind-Value="model.StartDate" />
            </div>

            <div class="mb-3">
                <label class="form-label">@Lang.Get("season.endDate")</label>
                <InputDate class="form-control" @bind-Value="model.EndDate" />
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger">@errorMessage</div>
            }

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary" disabled="@isLoading">
                    @if (isLoading)
                    {
                        <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                    }
                    @(isLoading ? Lang.Get("common.creating") : Lang.Get("common.create"))
                </button>
                <a href="/vaults/@VaultId" class="btn btn-outline-secondary">@Lang.Get("common.cancel")</a>
            </div>
        </EditForm>
    </div>
</div>
