@page "/cups/{id:int}"
@inherits LocalizedComponentBase
@attribute [Authorize]

<PageTitle>Cup - Futelo</PageTitle>

@if (isLoading)
{
    <div class="d-flex align-items-center gap-3 mb-4">
        <div class="skeleton-block" style="width:3.5rem;height:2rem"></div>
        <div class="skeleton-block" style="width:160px;height:1.75rem"></div>
        <div class="skeleton-block" style="width:4.5rem;height:1.5rem;border-radius:1rem"></div>
    </div>
    <div class="skeleton-block mb-2" style="width:100px;height:1rem"></div>
    <div class="card mb-2" style="max-width:520px">
        <div class="card-body py-2 px-3">
            <div class="d-flex justify-content-between align-items-center">
                <div class="skeleton-block" style="width:35%;height:.8rem"></div>
                <div class="skeleton-block" style="width:15%;height:.8rem"></div>
                <div class="skeleton-block" style="width:35%;height:.8rem"></div>
            </div>
        </div>
    </div>
    <div class="card mb-2" style="max-width:520px">
        <div class="card-body py-2 px-3">
            <div class="d-flex justify-content-between align-items-center">
                <div class="skeleton-block" style="width:35%;height:.8rem"></div>
                <div class="skeleton-block" style="width:15%;height:.8rem"></div>
                <div class="skeleton-block" style="width:35%;height:.8rem"></div>
            </div>
        </div>
    </div>
}
else if (cup == null)
{
    <p class="text-danger">@Lang.Get("cup.notFound")</p>
}
else
{
    <div class="d-flex align-items-center gap-3 mb-4">
        <a href="/seasons/@cup.SeasonId" class="btn btn-outline-secondary btn-sm">@Lang.Get("common.back")</a>
        <h3 class="mb-0">@cup.Name</h3>
        <span class="badge @BadgeHelper.StatusBadgeClass(cup.Status)">@cup.Status</span>
        @if (cup.IsHomeAndAway)
        {
            <span class="badge bg-info text-dark">@Lang.Get("season.homeAndAway")</span>
        }
        @if (cup.Status == "Finished" && cup.ChampionName != null)
        {
            <span class="badge bg-warning text-dark">🏆 @cup.ChampionName</span>
        }
    </div>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger mb-3">@errorMessage</div>
    }

    @if (cup.Status == "NotStarted")
    {
        <button class="btn btn-success mb-4" disabled="@isLoading" @onclick="HandleStart">
            @(isLoading ? Lang.Get("cup.generating") : Lang.Get("cup.generateBracket"))
        </button>
    }
    else
    {
        @if (lastResult != null)
        {
            <div class="alert alert-success mb-4" style="max-width:420px">
                <strong>@Lang.Get("common.resultRecorded")</strong>
                @if (lastResult.TieDecided)
                {
                    <div class="text-muted small">@Lang.Get("cup.tieDecided")</div>
                }
                <div class="mt-1">@FormatEloChange(lastResult.Home)</div>
                <div>@FormatEloChange(lastResult.Away)</div>
            </div>
        }

        @foreach (var round in cup.Rounds)
        {
            <h5 class="mt-3">@round.Name</h5>

            @foreach (var tie in GetTies(round))
            {
                <div class="card mb-3" style="max-width:520px">
                    <div class="card-body py-2 px-3">
                        @foreach (var match in tie)
                        {
                            var isEditable = cup.CanEdit && cup.Status != "NotStarted";
                            <div class="@(tie.Count > 1 ? "mb-2" : "") @(isEditable ? "match-card--editable" : "")"
                                 style="@(isEditable ? "cursor:pointer" : "")"
                                 @onclick="() => TryToggleEdit(match.Id)">
                                @if (cup.IsHomeAndAway)
                                {
                                    <span class="badge bg-secondary mb-1" style="font-size:.7rem">@Lang.Get("cup.leg") @match.Leg</span>
                                }
                                <div class="match-layout">
                                    <span class="@(string.IsNullOrEmpty(match.HomePlayerId) ? "text-muted" : "")">
                                        @match.HomePlayerName
                                    </span>
                                    @if (match.Status == "Played")
                                    {
                                        <span class="fw-bold text-center">
                                            @match.HomeScore – @match.AwayScore
                                            @if (match.WonOnPenaltiesId != null)
                                            {
                                                <span class="text-muted small">
                                                    (@(match.HomePenaltyScore)–@(match.AwayPenaltyScore) pen)
                                                </span>
                                            }
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted text-center">vs</span>
                                    }
                                    <span class="@(string.IsNullOrEmpty(match.AwayPlayerId) ? "text-muted" : "") text-end">
                                        @match.AwayPlayerName
                                    </span>
                                    @if (match.HomeTeamName != null || match.AwayTeamName != null)
                                    {
                                        <span class="match-meta__item">@match.HomeTeamName</span>
                                        <span></span>
                                        <span class="match-meta__item text-end">@match.AwayTeamName</span>
                                    }
                                </div>
                                @if (match.VideoGameName != null)
                                {
                                    <div class="match-meta__game">@match.VideoGameName</div>
                                }

                                @if (match.Status == "Pending" && cup.Status == "Active"
                                    && !string.IsNullOrEmpty(match.HomePlayerId)
                                    && !string.IsNullOrEmpty(match.AwayPlayerId))
                                {
                                    <div class="mt-2">
                                        <button class="btn btn-sm btn-outline-primary"
                                                @onclick:stopPropagation="true"
                                                @onclick="() => SelectMatch(match.Id, match.HomePlayerId, match.AwayPlayerId)">
                                            @(recordingMatchId == match.Id ? Lang.Get("common.cancel") : Lang.Get("cup.enterResult"))
                                        </button>
                                    </div>
                                }

                                @if (recordingMatchId == match.Id)
                                {
                                    <div @onclick:stopPropagation="true" @onclick="() => {}">
                                        <MatchResultForm
                                            HasPenalties="true"
                                            IsHomeAndAway="cup.IsHomeAndAway"
                                            IsLeg2="recordingIsLeg2"
                                            OtherLegHomeScore="otherLegHomeScore"
                                            OtherLegAwayScore="otherLegAwayScore"
                                            HomePlayerId="@recordingHomeId"
                                            HomePlayerName="@match.HomePlayerName"
                                            AwayPlayerId="@recordingAwayId"
                                            AwayPlayerName="@match.AwayPlayerName"
                                            IsSaving="isRecording"
                                            OnSave="HandleRecordResult"
                                            OnCancel="() => recordingMatchId = null" />
                                    </div>
                                }

                                <MatchEditPanel
                                    IsEditing="editingMatchId == match.Id"
                                    HomePlayerName="@match.HomePlayerName"
                                    AwayPlayerName="@match.AwayPlayerName"
                                    HomeTeamId="match.HomeTeamId"
                                    AwayTeamId="match.AwayTeamId"
                                    VideoGameId="match.VideoGameId"
                                    Teams="teams"
                                    VideoGames="videoGames"
                                    OnSave="HandlePatchMatch"
                                    OnCancel="() => editingMatchId = null" />
                            </div>
                        }

                        @if (cup.IsHomeAndAway && tie.All(m => m.Status == "Played"))
                        {
                            var agg = ComputeAggregate(tie);
                            <div class="text-muted small mt-1 border-top pt-1">
                                @Lang.Get("cup.aggregate"): @agg.homeName @agg.homeGoals – @agg.awayGoals @agg.awayName
                            </div>
                        }
                    </div>
                </div>
            }
        }
    }
}
