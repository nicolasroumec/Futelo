@page "/vaults/{vaultId:int}/seasons/{seasonId:int}/ranking"
@attribute [Authorize]

<PageTitle>Ranking - Futelo</PageTitle>

@if (isLoading)
{
    <SkeletonTable Columns="4" Rows="5" />
}
else
{
    <div class="d-flex align-items-center gap-3 mb-4">
        <a href="/seasons/@SeasonId" class="btn btn-outline-secondary btn-sm">@Lang.Get("common.back")</a>
        <h3 class="mb-0">@Lang.Get("stats.ranking")</h3>
    </div>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger mb-3">@errorMessage</div>
    }
    else if (rows.Count == 0)
    {
        <p class="empty-state">@Lang.Get("stats.noPlayersInSeason")</p>
    }
    else
    {
        <div class="table-responsive" style="max-width:540px">
            <table class="table table-sm table-bordered align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>@Lang.Get("stats.player")</th>
                        <th>@Lang.Get("stats.seasonElo")</th>
                        <th>@Lang.Get("stats.historicalElo")</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in rows)
                    {
                        <tr class="@(row.Position == 1 ? "rank-gold" : "")">
                            <td>@row.Position</td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <PlayerAvatar Name="@row.DisplayName" Size="24" />
                                    <a href="/vaults/@VaultId/players/@row.PlayerId" class="text-decoration-none">
                                        @row.DisplayName
                                    </a>
                                </div>
                            </td>
                            <td>@row.SeasonElo</td>
                            <td>@row.HistoricalElo</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}
