@page "/seasons/{id:int}"
@inherits LocalizedComponentBase
@attribute [Authorize]

<PageTitle>@(season?.Name ?? "Season") - Futelo</PageTitle>

@if (isLoading)
{
    <div class="d-flex align-items-center gap-3 mb-4">
        <div class="skeleton-block" style="width:3.5rem;height:2rem"></div>
        <div class="skeleton-block" style="width:160px;height:1.75rem"></div>
        <div class="skeleton-block" style="width:4.5rem;height:1.5rem;border-radius:1rem"></div>
    </div>
    <div class="skeleton-block mb-2" style="width:120px;height:.75rem"></div>
    <div class="skeleton-block mb-4" style="width:150px;height:.75rem"></div>
    <div class="d-flex gap-2 mb-4">
        <div class="skeleton-block" style="width:5rem;height:2rem"></div>
        <div class="skeleton-block" style="width:5rem;height:2rem"></div>
    </div>
    <div class="d-flex gap-2 mb-4">
        <div class="skeleton-block" style="width:5.5rem;height:1.5rem;border-radius:1rem"></div>
        <div class="skeleton-block" style="width:4.5rem;height:1.5rem;border-radius:1rem"></div>
    </div>
    <div class="skeleton-block mb-2" style="width:70px;height:1rem"></div>
    <ul class="list-group" style="max-width:520px">
        <li class="list-group-item"><div class="skeleton-block" style="height:.8rem;width:60%"></div></li>
        <li class="list-group-item"><div class="skeleton-block" style="height:.8rem;width:75%"></div></li>
        <li class="list-group-item"><div class="skeleton-block" style="height:.8rem;width:50%"></div></li>
        <li class="list-group-item"><div class="skeleton-block" style="height:.8rem;width:65%"></div></li>
    </ul>
}
else if (season == null)
{
    <p class="text-danger">@Lang.Get("season.notFound")</p>
}
else
{
    @* Breadcrumb *@
    <nav aria-label="breadcrumb" class="mb-2">
        <ol class="breadcrumb mb-0 small">
            <li class="breadcrumb-item">
                <a href="/dashboard" class="breadcrumb-link">@Lang.Get("nav.dashboard")</a>
            </li>
            <li class="breadcrumb-item">
                <a href="/vaults/@season.VaultId" class="breadcrumb-link">@season.VaultName</a>
            </li>
            <li class="breadcrumb-item active fw-semibold" aria-current="page">@season.Name</li>
        </ol>
    </nav>

    @* Header *@
    <div class="d-flex align-items-center gap-2 flex-wrap mb-3">
        <h3 class="mb-0 me-1">@season.Name</h3>
        <span class="badge @BadgeHelper.StatusBadgeClass(season.Status)">@Lang.Get("season.status." + season.Status.ToLower())</span>
    </div>

    @* Draft banner *@
    @if (isOwner && season.Status == "Draft")
    {
        <div class="d-flex align-items-center justify-content-between p-3 mb-3 rounded-3 season-draft-banner">
            <div>
                <div class="fw-semibold small">@Lang.Get("season.draftBannerTitle")</div>
                <div class="season-draft-banner__desc text-muted">@Lang.Get("season.draftBannerDesc")</div>
            </div>
            @if (season.Players.Count >= 2 && (season.HasLeague || season.HasCup))
            {
                <button class="btn btn-success btn-sm fw-semibold ms-3 flex-shrink-0"
                        @onclick="HandleActivate" disabled="@isActivating">
                    @if (isActivating)
                    {
                        <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                    }
                    @(isActivating ? Lang.Get("season.activating") : Lang.Get("season.startSeason") + " →")
                </button>
            }
        </div>

        @* Step wizard *@
        <div class="season-wizard d-flex align-items-center mb-4 overflow-auto pb-1">
            <div class="d-flex align-items-center gap-2 flex-shrink-0">
                <span class="badge rounded-pill @(StepCompDone ? "bg-success" : "bg-primary") d-inline-flex align-items-center justify-content-center season-wizard__badge">
                    @(StepCompDone ? "✓" : "1")
                </span>
                <span class="small fw-semibold">@Lang.Get("season.competitions")</span>
            </div>
            <div class="flex-fill mx-2 season-wizard__connector"></div>
            <div class="d-flex align-items-center gap-2 flex-shrink-0">
                @if (StepPlayersDone)
                {
                    <span class="badge rounded-pill bg-success d-inline-flex align-items-center justify-content-center season-wizard__badge">✓</span>
                    <span class="small fw-semibold">@Lang.Get("season.players")</span>
                }
                else if (StepCompDone)
                {
                    <span class="badge rounded-pill bg-primary d-inline-flex align-items-center justify-content-center season-wizard__badge">2</span>
                    <span class="small fw-semibold">@Lang.Get("season.players")</span>
                }
                else
                {
                    <span class="badge rounded-pill bg-secondary d-inline-flex align-items-center justify-content-center season-wizard__badge season-wizard__badge--dim">2</span>
                    <span class="small text-muted">@Lang.Get("season.players")</span>
                }
            </div>
            <div class="flex-fill mx-2 season-wizard__connector"></div>
            <div class="d-flex align-items-center gap-2 flex-shrink-0">
                @if (StepReadyToActivate)
                {
                    <span class="badge rounded-pill bg-primary d-inline-flex align-items-center justify-content-center season-wizard__badge">3</span>
                    <span class="small fw-semibold">@Lang.Get("season.stepActivate")</span>
                }
                else
                {
                    <span class="badge rounded-pill bg-secondary d-inline-flex align-items-center justify-content-center season-wizard__badge season-wizard__badge--dim">3</span>
                    <span class="small text-muted">@Lang.Get("season.stepActivate")</span>
                }
            </div>
        </div>
    }

    @* Metadata line: dates · video game · year *@
    <div class="season-meta mb-3">
        @if (editingSeasonDates)
        {
            <div class="d-flex align-items-center gap-2 flex-wrap">
                <input type="date" class="form-control form-control-sm" style="width:160px" @bind="editSeasonStartDate" />
                <span class="text-muted">→</span>
                <input type="date" class="form-control form-control-sm" style="width:160px" @bind="editSeasonEndDate" />
                <button class="btn btn-sm btn-primary" disabled="@isSavingSeasonDates" @onclick="HandlePatchSeasonDates">
                    @if (isSavingSeasonDates)
                    {
                        <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                    }
                    @(isSavingSeasonDates ? Lang.Get("common.saving") : Lang.Get("common.save"))
                </button>
                <button class="btn btn-sm btn-outline-secondary" @onclick="() => editingSeasonDates = false">@Lang.Get("common.cancel")</button>
            </div>
        }
        else
        {
            <span class="season-meta__item">
                📅 @(season.StartDate.HasValue ? season.StartDate.Value.ToString("dd MMM yyyy") : "—") → @(season.EndDate.HasValue ? season.EndDate.Value.ToString("dd MMM yyyy") : "—")
                @if (isOwner && (season.Status == "Draft" || season.Status == "Active"))
                {
                    <button class="btn btn-link btn-sm p-0 ms-1 text-muted" @onclick="BeginEditSeasonDates">✏️</button>
                }
            </span>
            <span class="season-meta__sep">·</span>
            <span class="season-meta__item">🎮 @(season.VideoGameName ?? "—")</span>
            <span class="season-meta__sep">·</span>
            <span class="season-meta__item">@season.Year</span>
        }
    </div>

    @* Video game selector (owners only, editable states) *@
    @if (isOwner && (season.Status == "Draft" || season.Status == "Active"))
    {
        <div class="d-flex align-items-center gap-2 mb-4" style="max-width:320px">
            <select class="form-select form-select-sm" @bind="selectedVideoGameId">
                <option value="">@Lang.Get("common.none")</option>
                @foreach (var g in videoGames)
                {
                    <option value="@g.Id">@g.Name</option>
                }
            </select>
            <button class="btn btn-outline-secondary btn-sm flex-shrink-0" disabled="@isPatchingVideoGame"
                    @onclick="HandlePatchVideoGame">
                @if (isPatchingVideoGame)
                {
                    <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                }
                @(isPatchingVideoGame ? Lang.Get("common.saving") : Lang.Get("common.save"))
            </button>
        </div>
    }

    @* Competition cards *@
    @if (season.HasLeague || season.HasCup || season.HasSuperCup)
    {
        <div class="season-competitions mb-4">
            @if (season.HasLeague)
            {
                @if (season.LeagueId.HasValue)
                {
                    <a href="/leagues/@season.LeagueId" class="season-comp-card season-comp-card--league">
                        <div class="season-comp-card__body">
                            <span class="season-comp-card__name">@season.LeagueName</span>
                            @if (season.LeagueStatus != null)
                            {
                                <span class="badge @BadgeHelper.StatusBadgeClass(season.LeagueStatus)">@Lang.Get("competition.status." + season.LeagueStatus.ToLower())</span>
                            }
                        </div>
                        <span class="season-comp-card__arrow">→</span>
                    </a>
                }
                else
                {
                    <div class="season-comp-card season-comp-card--league season-comp-card--pending">
                        <div class="season-comp-card__body">
                            <span class="season-comp-card__name">@season.LeagueName</span>
                            <span class="badge bg-secondary">@Lang.Get("competition.status.notstarted")</span>
                        </div>
                    </div>
                }
            }
            @if (season.HasCup)
            {
                @if (season.CupId.HasValue)
                {
                    <a href="/cups/@season.CupId" class="season-comp-card season-comp-card--cup">
                        <div class="season-comp-card__body">
                            <span class="season-comp-card__name">@season.CupName</span>
                            @if (season.CupStatus != null)
                            {
                                <span class="badge @BadgeHelper.StatusBadgeClass(season.CupStatus)">@Lang.Get("competition.status." + season.CupStatus.ToLower())</span>
                            }
                        </div>
                        <span class="season-comp-card__arrow">→</span>
                    </a>
                }
                else
                {
                    <div class="season-comp-card season-comp-card--cup season-comp-card--pending">
                        <div class="season-comp-card__body">
                            <span class="season-comp-card__name">@season.CupName</span>
                            <span class="badge bg-secondary">@Lang.Get("competition.status.notstarted")</span>
                        </div>
                    </div>
                }
            }
            @if (season.HasSuperCup)
            {
                @if (season.SuperCupId.HasValue)
                {
                    <a href="/supercups/@season.SuperCupId" class="season-comp-card season-comp-card--supercup">
                        <div class="season-comp-card__body">
                            <span class="season-comp-card__name">@season.SuperCupName</span>
                            @if (season.SuperCupStatus != null)
                            {
                                <span class="badge @BadgeHelper.StatusBadgeClass(season.SuperCupStatus)">@Lang.Get("competition.status." + season.SuperCupStatus.ToLower())</span>
                            }
                        </div>
                        <span class="season-comp-card__arrow">→</span>
                    </a>
                }
                else
                {
                    <div class="season-comp-card season-comp-card--supercup season-comp-card--pending">
                        <div class="season-comp-card__body">
                            <span class="season-comp-card__name">@season.SuperCupName</span>
                            <span class="badge bg-secondary">@Lang.Get("competition.status.notstarted")</span>
                        </div>
                    </div>
                }
            }
        </div>
    }

    @* Actions toolbar *@
    <div class="d-flex flex-wrap align-items-center gap-2 mb-4">
        <a href="/vaults/@season.VaultId/seasons/@season.Id/ranking" class="btn btn-outline-secondary btn-sm">@Lang.Get("stats.ranking")</a>
        @if (season.Status == "Finished")
        {
            <a href="/seasons/@season.Id/recap" class="btn btn-outline-secondary btn-sm">@Lang.Get("season.recap")</a>
            <button class="btn btn-outline-secondary btn-sm" @onclick="CopyRecapLink">@Lang.Get("season.copyRecapLink")</button>
        }
        @if (isOwner && season.Status == "Active")
        {
            <span class="season-actions-sep"></span>
            @if (!CanFinish)
            {
                <span class="text-muted small">@Lang.Get("season.finishWarning")</span>
            }
            <button class="btn btn-outline-danger btn-sm" disabled="@(!CanFinish || isFinishing)"
                    @onclick="HandleFinish">
                @if (isFinishing)
                {
                    <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                }
                @(isFinishing ? Lang.Get("season.finishing") : Lang.Get("season.finishSeason"))
            </button>
        }
    </div>

    @* Main content *@
    <div class="row g-4">
        <div class="@(HasRightContent ? "col-lg-5" : "col-12")">
            <h5>@Lang.Get("season.players")</h5>
            @if (season.Players.Count == 0)
            {
                <EmptyState Message="@Lang.Get("season.noPlayers")" />
            }
            else
            {
                <ul class="list-group mb-4">
                    @foreach (var p in season.Players)
                    {
                        <li class="list-group-item" @key="@p.PlayerId">
                            <div class="d-flex justify-content-between align-items-center">
                                <span>@p.DisplayName</span>
                                <span class="badge bg-light text-dark">ELO @p.SeasonElo</span>
                            </div>
                            @if (isOwner && (season.Status == "Draft" || season.Status == "Active"))
                            {
                                <SeasonTeamSelector InitialTeamId="@p.TeamId"
                                                    Teams="@teams"
                                                    OnSave="@(teamId => HandleSetPlayerTeam(p.PlayerId, teamId))" />
                            }
                            else if (!string.IsNullOrEmpty(p.TeamName))
                            {
                                <small class="text-muted">@p.TeamName</small>
                            }
                        </li>
                    }
                </ul>
            }
        </div>

        @if (HasRightContent)
        {
            <div class="col-lg-7">
                @if (season.TopStandings.Count > 0)
                {
                    <h5>@Lang.Get("league.standings")</h5>
                    <div class="table-responsive mb-4">
                        <table class="table table-sm table-bordered align-middle">
                            <thead class="table-dark">
                                <tr>
                                    <th>#</th>
                                    <th>@Lang.Get("stats.player")</th>
                                    <th>@Lang.Get("stats.played")</th>
                                    <th>@Lang.Get("stats.wins")</th>
                                    <th>@Lang.Get("stats.draws")</th>
                                    <th>@Lang.Get("stats.losses")</th>
                                    <th>@Lang.Get("league.points")</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{ int pos = 1; }
                                @foreach (var row in season.TopStandings)
                                {
                                    <tr class="@(pos == 1 ? "rank-gold" : "")">
                                        <td>@pos</td>
                                        <td>@row.DisplayName</td>
                                        <td>@row.Played</td>
                                        <td>@row.Won</td>
                                        <td>@row.Drawn</td>
                                        <td>@row.Lost</td>
                                        <td><strong>@row.Points</strong></td>
                                    </tr>
                                    pos++;
                                }
                            </tbody>
                        </table>
                    </div>
                }

                @if (season.RecentMatches.Count > 0)
                {
                    <h5>@Lang.Get("vault.recentMatches")</h5>
                    <div class="d-flex flex-column gap-2 mb-4">
                        @foreach (var m in season.RecentMatches)
                        {
                            <div class="recent-match-row">
                                <span class="recent-match-competition text-muted small">@m.Competition</span>
                                <MatchDisplay HomePlayerName="@m.HomePlayerName"
                                              AwayPlayerName="@m.AwayPlayerName"
                                              HomeScore="@m.HomeScore"
                                              AwayScore="@m.AwayScore"
                                              IsPlayed="true" />
                            </div>
                        }
                    </div>
                }

                @if (isOwner && season.Status == "Draft")
                {
                    <h5>@Lang.Get("season.configureSeason")</h5>

                    <SeasonPlayerManager VaultPlayers="@vaultPlayers" SelectedPlayerIds="@selectedPlayerIds" />

                    <SeasonCompetitionConfig Model="@configureModel" />

                    <button class="btn btn-primary" disabled="@isConfiguring" @onclick="HandleConfigure">
                        @if (isConfiguring)
                        {
                            <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                        }
                        @(isConfiguring ? Lang.Get("common.saving") : Lang.Get("season.saveConfig"))
                    </button>

                    @if (season.Players.Count >= 2 && (season.HasLeague || season.HasCup))
                    {
                        <div class="mt-3">
                            <button class="btn btn-success" disabled="@isActivating" @onclick="HandleActivate">
                                @if (isActivating)
                                {
                                    <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                                }
                                @(isActivating ? Lang.Get("season.activating") : Lang.Get("season.startSeason"))
                            </button>
                        </div>
                    }
                }
            </div>
        }
    </div>
}

@if (isOwner && season != null)
{
    <div class="mt-5 pt-3 border-top">
        <button class="btn btn-link btn-sm text-danger p-0" style="font-size:.78rem;opacity:.6"
                @onclick="() => showDeleteModal = true">
            @Lang.Get("season.deleteSeason")
        </button>
    </div>
}

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger mt-3">@errorMessage</div>
}

@if (showDeleteModal)
{
    <div class="modal-backdrop fade show"></div>
    <div class="modal d-block" tabindex="-1" role="dialog" @onclick="() => showDeleteModal = false">
        <div class="modal-dialog modal-dialog-centered modal-sm" @onclick:stopPropagation>
            <div class="modal-content">
                <div class="modal-body p-4">
                    <h6 class="fw-bold mb-1">@Lang.Get("season.deleteSeason")</h6>
                    <p class="text-muted small mb-4">@Lang.Get("season.deleteWarning")</p>
                    <div class="d-flex gap-2 justify-content-end">
                        <button type="button" class="btn btn-outline-secondary btn-sm"
                                @onclick="() => showDeleteModal = false">
                            @Lang.Get("common.cancel")
                        </button>
                        <button type="button" class="btn btn-danger btn-sm fw-semibold"
                                disabled="@isDeleting" @onclick="HandleDelete">
                            @if (isDeleting)
                            {
                                <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                            }
                            @(isDeleting ? Lang.Get("common.deleting") : Lang.Get("common.confirmDelete"))
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
}
