@page "/invitations/{token}/accept"
@inherits LocalizedComponentBase
@attribute [Authorize]

<PageTitle>Accept Invitation - Futelo</PageTitle>

<div class="row justify-content-center mt-5">
    <div class="col-md-4 text-center">
        @if (isLoading)
        {
            <div class="d-flex flex-column align-items-center gap-3 py-4">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">@Lang.Get("invitation.processing")</span>
                </div>
                <span class="text-muted small">@Lang.Get("invitation.processing")</span>
            </div>
        }
        else if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger">@errorMessage</div>
            <a href="/dashboard" class="btn btn-outline-secondary mt-2">@Lang.Get("invitation.goToDashboard")</a>
        }
        else
        {
            <div class="alert alert-success">@Lang.Get("invitation.joinedSuccess")</div>
            <a href="/dashboard" class="btn btn-primary mt-2">@Lang.Get("invitation.goToDashboard")</a>
        }
    </div>
</div>
