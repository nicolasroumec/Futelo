@using Futelo.Shared.DTOs.League
@using Futelo.Shared.DTOs.Team
@using Futelo.Shared.DTOs.VideoGame

@if (IsEditing)
{
    <div class="match-edit-form border-top pt-2 mt-2" @onclick:stopPropagation="true">
        <div class="d-flex justify-content-between align-items-end gap-2">
            <div>
                <label class="form-label form-label-sm mb-1">@HomePlayerName</label>
                <select class="form-select form-select-sm" style="width:140px" @bind="editHomeTeamIdStr">
                    <option value="">@Lang.Get("common.none")</option>
                    @foreach (var t in Teams)
                    {
                        <option value="@t.Id">@t.Name</option>
                    }
                </select>
            </div>
            <div class="text-end">
                <label class="form-label form-label-sm mb-1">@AwayPlayerName</label>
                <select class="form-select form-select-sm" style="width:140px" @bind="editAwayTeamIdStr">
                    <option value="">@Lang.Get("common.none")</option>
                    @foreach (var t in Teams)
                    {
                        <option value="@t.Id">@t.Name</option>
                    }
                </select>
            </div>
        </div>
        <div class="text-center mt-1">
            <label class="form-label form-label-sm mb-1">@Lang.Get("season.videoGame")</label>
            <select class="form-select form-select-sm" style="width:140px" @bind="editVideoGameIdStr">
                <option value="">@Lang.Get("common.none")</option>
                @foreach (var vg in VideoGames)
                {
                    <option value="@vg.Id">@vg.Name</option>
                }
            </select>
        </div>
        <div class="text-center mt-1">
            <label class="form-label form-label-sm mb-1">@Lang.Get("match.scheduledDate")</label>
            <input type="date" class="form-control form-control-sm" style="width:160px;margin:0 auto"
                   @bind="editScheduledDate" />
        </div>
        <div class="d-flex gap-2 mt-2">
            <button class="btn btn-sm btn-primary" disabled="@isSaving" @onclick="HandleSave">
                @if (isSaving)
                {
                    <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                }
                @Lang.Get("common.save")
            </button>
            <button class="btn btn-sm btn-outline-secondary" @onclick="HandleCancel">
                @Lang.Get("common.cancel")
            </button>
        </div>
    </div>
}
