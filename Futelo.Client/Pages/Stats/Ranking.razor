@page "/vaults/{vaultId:int}/seasons/{seasonId:int}/ranking"
@attribute [Authorize]

<PageTitle>Ranking - Futelo</PageTitle>

@if (isLoading)
{
    <p>Loading...</p>
}
else
{
    <div class="d-flex align-items-center gap-3 mb-4">
        <a href="/seasons/@SeasonId" class="btn btn-outline-secondary btn-sm">Back</a>
        <h3 class="mb-0">Ranking</h3>
    </div>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger mb-3">@errorMessage</div>
    }
    else if (rows.Count == 0)
    {
        <p class="empty-state">No players in this season.</p>
    }
    else
    {
        <div class="table-responsive" style="max-width:540px">
            <table class="table table-sm table-bordered align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Player</th>
                        <th>Season ELO</th>
                        <th>Historical ELO</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in rows)
                    {
                        <tr>
                            <td>@row.Position</td>
                            <td>
                                <a href="/vaults/@VaultId/players/@row.PlayerId" class="text-decoration-none">
                                    @row.DisplayName
                                </a>
                            </td>
                            <td>@row.SeasonElo</td>
                            <td>@row.HistoricalElo</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}
