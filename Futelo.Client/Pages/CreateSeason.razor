@page "/vaults/{vaultId:int}/seasons/create"
@attribute [Authorize]

<PageTitle>New Season - Futelo</PageTitle>

<div class="row justify-content-center mt-4">
    <div class="col-md-5">
        <div class="d-flex align-items-center gap-3 mb-4">
            <a href="/vaults/@VaultId" class="btn btn-outline-secondary btn-sm">Back</a>
            <h3 class="mb-0">New Season</h3>
        </div>

        <EditForm Model="model" OnValidSubmit="HandleCreate">
            <DataAnnotationsValidator />

            <div class="mb-3">
                <label class="form-label">Name</label>
                <InputText class="form-control" @bind-Value="model.Name" placeholder="e.g. Season 2026" />
                <ValidationMessage For="() => model.Name" />
            </div>

            <div class="mb-3">
                <label class="form-label">Year</label>
                <InputNumber class="form-control" @bind-Value="model.Year" />
                <ValidationMessage For="() => model.Year" />
            </div>

            <div class="mb-3">
                <label class="form-label">Video Game</label>
                <InputSelect class="form-select" @bind-Value="model.VideoGameId">
                    <option value="">— None —</option>
                    @foreach (var g in videoGames)
                    {
                        <option value="@g.Id">@g.Name</option>
                    }
                </InputSelect>
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger">@errorMessage</div>
            }

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary" disabled="@isLoading">
                    @(isLoading ? "Creating..." : "Create")
                </button>
                <a href="/vaults/@VaultId" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </EditForm>
    </div>
</div>
