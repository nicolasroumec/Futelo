@page "/seasons/{id:int}/recap"

<PageTitle>@(recap != null ? $"{recap.SeasonName} {recap.Year} – Recap" : "Season Recap") - Futelo</PageTitle>

<div class="container-sm py-4" style="max-width:680px">
    @if (isLoading)
    {
        <div class="skeleton-block mb-3" style="width:200px;height:2rem"></div>
        <div class="skeleton-block mb-4" style="width:120px;height:1rem"></div>
        <div class="row g-3 mb-4">
            <div class="col-6"><div class="skeleton-block" style="height:5rem;border-radius:.5rem"></div></div>
            <div class="col-6"><div class="skeleton-block" style="height:5rem;border-radius:.5rem"></div></div>
        </div>
        <div class="row g-3">
            <div class="col-4"><div class="skeleton-block" style="height:4rem;border-radius:.5rem"></div></div>
            <div class="col-4"><div class="skeleton-block" style="height:4rem;border-radius:.5rem"></div></div>
            <div class="col-4"><div class="skeleton-block" style="height:4rem;border-radius:.5rem"></div></div>
        </div>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger">@errorMessage</div>
    }
    else if (recap is not null)
    {
        <div class="d-flex align-items-center gap-3 mb-1">
            <h2 class="mb-0">@recap.SeasonName</h2>
            <span class="text-muted fs-5">@recap.Year</span>
        </div>
        <p class="text-muted mb-4">@recap.TotalMatches matches · @recap.TotalGoals goals</p>

        @if (recap.LeagueChampion is not null || recap.CupChampion is not null || recap.SuperCupChampion is not null)
        {
            <div class="row g-3 mb-4">
                @if (recap.LeagueChampion is not null)
                {
                    <div class="col-sm-4">
                        <div class="card text-center h-100 border-primary">
                            <div class="card-body py-3">
                                <div class="fs-4 mb-1">🏆</div>
                                <div class="fw-bold">@recap.LeagueChampion</div>
                                <div class="text-muted small">@Lang.Get("competition.league")</div>
                            </div>
                        </div>
                    </div>
                }
                @if (recap.CupChampion is not null)
                {
                    <div class="col-sm-4">
                        <div class="card text-center h-100 border-success">
                            <div class="card-body py-3">
                                <div class="fs-4 mb-1">🥇</div>
                                <div class="fw-bold">@recap.CupChampion</div>
                                <div class="text-muted small">@Lang.Get("competition.cup")</div>
                            </div>
                        </div>
                    </div>
                }
                @if (recap.SuperCupChampion is not null)
                {
                    <div class="col-sm-4">
                        <div class="card text-center h-100 border-warning">
                            <div class="card-body py-3">
                                <div class="fs-4 mb-1">⭐</div>
                                <div class="fw-bold">@recap.SuperCupChampion</div>
                                <div class="text-muted small">Super Cup</div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }

        <div class="row g-3 mb-4">
            @if (recap.TopScorerName is not null)
            {
                <div class="col-sm-6">
                    <div class="card h-100">
                        <div class="card-body py-3">
                            <div class="text-muted small mb-1">Top scorer</div>
                            <div class="fw-bold">@recap.TopScorerName</div>
                            <div class="fs-5">@recap.TopScorerGoals goals</div>
                        </div>
                    </div>
                </div>
            }
            @if (recap.MostImprovedName is not null)
            {
                <div class="col-sm-6">
                    <div class="card h-100">
                        <div class="card-body py-3">
                            <div class="text-muted small mb-1">Most improved</div>
                            <div class="fw-bold">@recap.MostImprovedName</div>
                            <div class="fs-5 text-success">+@recap.MostImprovedEloGain ELO</div>
                        </div>
                    </div>
                </div>
            }
            @if (recap.BiggestWinHome is not null)
            {
                <div class="col-sm-6">
                    <div class="card h-100">
                        <div class="card-body py-3">
                            <div class="text-muted small mb-1">Biggest win</div>
                            <div class="fw-bold">@recap.BiggestWinHome @recap.BiggestWinHomeScore – @recap.BiggestWinAwayScore @recap.BiggestWinAway</div>
                        </div>
                    </div>
                </div>
            }
            @if (recap.LongestStreakPlayer is not null && recap.LongestStreak > 1)
            {
                <div class="col-sm-6">
                    <div class="card h-100">
                        <div class="card-body py-3">
                            <div class="text-muted small mb-1">Longest win streak</div>
                            <div class="fw-bold">@recap.LongestStreakPlayer</div>
                            <div class="fs-5">@recap.LongestStreak wins</div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <button class="btn btn-outline-secondary btn-sm" @onclick="CopyLink">
            Copy link
        </button>
    }
</div>
