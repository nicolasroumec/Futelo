@page "/vaults/{id:int}"
@attribute [Authorize]
@using Futelo.Shared.Enums

<PageTitle>@(vault?.Name ?? "Vault") - Futelo</PageTitle>

@if (isLoading)
{
    <p>Loading...</p>
}
else if (vault == null)
{
    <p class="text-danger">Vault not found.</p>
}
else
{
    <div class="d-flex align-items-center gap-3 mb-4">
        <a href="/dashboard" class="btn btn-outline-secondary btn-sm">Back</a>
        <h3 class="mb-0">@vault.Name</h3>
    </div>

    <p class="text-muted">Owner: @vault.OwnerDisplayName</p>

    <h5 class="mt-4">Players</h5>
    <ul class="list-group mb-4" style="max-width:420px">
        @foreach (var player in vault.Players)
        {
            <li class="list-group-item d-flex justify-content-between align-items-center">
                <a href="/vaults/@Id/players/@player.PlayerId" class="text-decoration-none">@player.DisplayName</a>
                <span class="badge @RoleBadgeClass(player.Role)">@player.Role</span>
            </li>
        }
    </ul>

    <div class="d-flex gap-2 mb-4">
        <a href="/vaults/@Id/ranking" class="btn btn-outline-secondary btn-sm">Ranking</a>
        <a href="/vaults/@Id/scorers" class="btn btn-outline-secondary btn-sm">Scorers</a>
        <a href="/vaults/@Id/records" class="btn btn-outline-secondary btn-sm">Records</a>
        <a href="/vaults/@Id/palmares" class="btn btn-outline-secondary btn-sm">Palmarés</a>
        <a href="/vaults/@Id/teams" class="btn btn-outline-secondary btn-sm">Teams</a>
        <a href="/vaults/@Id/games" class="btn btn-outline-secondary btn-sm">Games</a>
    </div>

    <div class="d-flex align-items-center gap-3 mt-4 mb-2">
        <h5 class="mb-0">Seasons</h5>
        @if (isOwner)
        {
            <a href="/vaults/@Id/seasons/create" class="btn btn-outline-primary btn-sm">+ New Season</a>
        }
    </div>
    @if (seasons.Count == 0)
    {
        <p class="text-muted">No seasons yet.</p>
    }
    else
    {
        <ul class="list-group mb-4" style="max-width:420px">
            @foreach (var s in seasons)
            {
                <li class="list-group-item d-flex justify-content-between align-items-center">
                    <a href="/seasons/@s.Id" class="text-decoration-none">@s.Name (@s.Year)</a>
                    <span class="badge bg-secondary">@s.Status</span>
                </li>
            }
        </ul>
    }

    @if (isAdmin)
    {
        <h5>Invite Player</h5>
        <EditForm Model="inviteModel" OnValidSubmit="HandleInvite" style="max-width:420px">
            <DataAnnotationsValidator />
            <div class="input-group mb-2">
                <InputSelect class="form-select" @bind-Value="inviteModel.Role">
                    <option value="@VaultRole.Viewer">Viewer</option>
                    <option value="@VaultRole.Editor">Editor</option>
                    <option value="@VaultRole.Admin">Admin</option>
                </InputSelect>
                <button type="submit" class="btn btn-outline-primary" disabled="@isInviting">
                    @(isInviting ? "Generating..." : "Generate Link")
                </button>
            </div>
        </EditForm>

        @if (!string.IsNullOrEmpty(inviteLink))
        {
            <div class="input-group mt-2" style="max-width:420px">
                <input class="form-control form-control-sm" readonly value="@inviteLink" />
                <button class="btn btn-outline-secondary btn-sm" @onclick="CopyInviteLink">Copy</button>
            </div>
        }

        @if (!string.IsNullOrEmpty(inviteMessage))
        {
            <div class="alert @inviteAlertClass mt-2">@inviteMessage</div>
        }
    }
}

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger mt-3">@errorMessage</div>
}
