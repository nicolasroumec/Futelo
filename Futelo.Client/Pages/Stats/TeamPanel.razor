@page "/vaults/{vaultId:int}/teams"
@attribute [Authorize]

<PageTitle>Teams - Futelo</PageTitle>

@if (isLoading)
{
    <SkeletonTable Columns="8" Rows="5" />
}
else
{
    <div class="d-flex align-items-center gap-3 mb-4">
        <a href="/vaults/@VaultId" class="btn btn-outline-secondary btn-sm">@Lang.Get("common.back")</a>
        <h3 class="mb-0">@Lang.Get("stats.teamPanel")</h3>
    </div>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger mb-3">@errorMessage</div>
    }
    else if (rows.Count == 0)
    {
        <p class="empty-state">@Lang.Get("stats.noMatches")</p>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-sm table-bordered align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>@Lang.Get("stats.team")</th>
                        <th>@Lang.Get("stats.played")</th>
                        <th>@Lang.Get("stats.wins")</th>
                        <th>@Lang.Get("stats.draws")</th>
                        <th>@Lang.Get("stats.losses")</th>
                        <th>@Lang.Get("league.goalsFor")</th>
                        <th>@Lang.Get("league.goalsAgainst")</th>
                        <th>@Lang.Get("stats.usedBy")</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var t in rows)
                    {
                        <tr>
                            <td><strong>@t.TeamName</strong></td>
                            <td>@t.TotalUsed</td>
                            <td>@t.Won</td>
                            <td>@t.Drawn</td>
                            <td>@t.Lost</td>
                            <td>@t.GoalsFor</td>
                            <td>@t.GoalsAgainst</td>
                            <td>
                                @foreach (var p in t.Players)
                                {
                                    <a href="/vaults/@VaultId/players/@p.PlayerId"
                                       class="badge bg-secondary text-decoration-none me-1">
                                        @p.DisplayName (@p.TimesUsed)
                                    </a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}
