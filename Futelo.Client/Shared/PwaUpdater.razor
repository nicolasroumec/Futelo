@namespace Futelo.Client.Shared
@inject ILanguageService Lang

@if (_updateAvailable)
{
    <div class="pwa-update-banner" role="alert">
        <span class="pwa-update-banner__text">@Lang.Get("pwa.updateAvailable")</span>
        <button class="pwa-update-banner__btn" @onclick="ApplyUpdateAsync">@Lang.Get("pwa.reload")</button>
        <button class="pwa-update-banner__dismiss" @onclick="Dismiss" aria-label="Dismiss">&#x2715;</button>
    </div>
}
