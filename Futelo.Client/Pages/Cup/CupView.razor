@page "/cups/{id:int}"
@inherits LocalizedComponentBase
@attribute [Authorize]

<PageTitle>@(cup?.Name ?? "Cup") - Futelo</PageTitle>

@if (isLoading)
{
    <div class="d-flex align-items-center gap-3 mb-4">
        <div class="skeleton-block" style="width:3.5rem;height:2rem"></div>
        <div class="skeleton-block" style="width:160px;height:1.75rem"></div>
        <div class="skeleton-block" style="width:4.5rem;height:1.5rem;border-radius:1rem"></div>
    </div>
    <div class="skeleton-block mb-2" style="width:100px;height:1rem"></div>
    <div class="card mb-2" style="max-width:520px">
        <div class="card-body py-2 px-3">
            <div class="d-flex justify-content-between align-items-center">
                <div class="skeleton-block" style="width:35%;height:.8rem"></div>
                <div class="skeleton-block" style="width:15%;height:.8rem"></div>
                <div class="skeleton-block" style="width:35%;height:.8rem"></div>
            </div>
        </div>
    </div>
    <div class="card mb-2" style="max-width:520px">
        <div class="card-body py-2 px-3">
            <div class="d-flex justify-content-between align-items-center">
                <div class="skeleton-block" style="width:35%;height:.8rem"></div>
                <div class="skeleton-block" style="width:15%;height:.8rem"></div>
                <div class="skeleton-block" style="width:35%;height:.8rem"></div>
            </div>
        </div>
    </div>
}
else if (cup == null)
{
    <EmptyState Message="@Lang.Get("cup.notFound")" />
}
else
{
    <nav aria-label="breadcrumb" class="mb-2">
        <ol class="breadcrumb mb-0 small">
            <li class="breadcrumb-item">
                <a href="/dashboard" class="breadcrumb-link">@Lang.Get("nav.dashboard")</a>
            </li>
            <li class="breadcrumb-item">
                <a href="/vaults/@cup.VaultId" class="breadcrumb-link">@cup.VaultName</a>
            </li>
            <li class="breadcrumb-item">
                <a href="/seasons/@cup.SeasonId" class="breadcrumb-link">@cup.SeasonName</a>
            </li>
            <li class="breadcrumb-item active fw-semibold" aria-current="page">@cup.Name</li>
        </ol>
    </nav>
    <div class="d-flex align-items-center gap-2 flex-wrap mb-3">
        <h3 class="mb-0 me-1">@cup.Name</h3>
        <span class="badge @BadgeHelper.StatusBadgeClass(cup.Status)">@Lang.Get("competition.status." + cup.Status.ToLower())</span>
        @if (cup.IsHomeAndAway)
        {
            <span class="badge bg-info text-dark">@Lang.Get("season.homeAndAway")</span>
        }
        @if (cup.Status == "Finished" && cup.ChampionName != null)
        {
            <span class="badge bg-warning text-dark">🏆 @cup.ChampionName</span>
        }
    </div>

    @if (editingDates)
    {
        <div class="d-flex align-items-center gap-2 mb-3 flex-wrap">
            <input type="date" class="form-control form-control-sm" style="width:160px" @bind="editStartDate" />
            <span class="text-muted">→</span>
            <input type="date" class="form-control form-control-sm" style="width:160px" @bind="editEndDate" />
            <button class="btn btn-sm btn-primary" disabled="@isSavingDates" @onclick="HandlePatchDates">
                @if (isSavingDates)
                {
                    <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                }
                @(isSavingDates ? Lang.Get("common.saving") : Lang.Get("common.save"))
            </button>
            <button class="btn btn-sm btn-outline-secondary" @onclick="() => editingDates = false">@Lang.Get("common.cancel")</button>
        </div>
    }
    else
    {
        <div class="d-flex align-items-center gap-2 mb-3 text-muted small">
            <span>📅 @(cup.StartDate.HasValue ? cup.StartDate.Value.ToString("dd MMM yyyy") : "—") → @(cup.EndDate.HasValue ? cup.EndDate.Value.ToString("dd MMM yyyy") : "—")</span>
            @if (cup.CanEdit)
            {
                <button class="btn btn-link btn-sm p-0 text-muted" @onclick="BeginEditDates">✏️</button>
            }
        </div>
    }

    <div class="text-muted small mb-3 d-flex gap-3">
        <span>@Lang.Get("cup.seedingMode"): <strong>@Lang.Get(SeedingModeKey)</strong></span>
        @if (cup.IsHomeAndAway)
        {
            <span>· @Lang.Get("season.homeAndAway")</span>
        }
        @if (cup.AwayGoalRule)
        {
            <span>· @Lang.Get("cup.awayGoalRule")</span>
        }
    </div>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger mb-3">@errorMessage</div>
    }

    @if (cup.Status == "NotStarted")
    {
        <div class="d-flex gap-2 mb-4">
            <button class="btn btn-success" disabled="@isWorking" @onclick="HandleStart">
                @if (isWorking)
                {
                    <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                }
                @(isWorking ? Lang.Get("cup.generating") : Lang.Get("cup.generateBracket"))
            </button>
            @if (cup.CanEdit)
            {
                <button class="btn btn-outline-secondary" disabled="@isWorking" @onclick="HandleStartManual">
                    @if (isWorking)
                    {
                        <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                    }
                    @Lang.Get("cup.startManual")
                </button>
            }
        </div>
    }
    else
    {
        @if (!cup.IsManual)
        {
            <div class="d-flex gap-2 mb-3">
                <button class="btn btn-sm @(showBracket ? "btn-primary" : "btn-outline-secondary")"
                        @onclick="() => showBracket = true">
                    🏆 @Lang.Get("cup.viewBracket")
                </button>
                <button class="btn btn-sm @(!showBracket ? "btn-primary" : "btn-outline-secondary")"
                        @onclick="() => showBracket = false">
                    📋 @Lang.Get("cup.viewRounds")
                </button>
            </div>
        }

        @if (showBracket && !cup.IsManual)
        {
            <CupBracket Cup="cup" />
        }
        else
        {

        @foreach (var round in cup.Rounds)
        {
            <h5 class="mt-3">@round.Name</h5>
            <div class="row g-3 mb-2">
                @foreach (var tie in GetTies(round))
                {
                    <div class="col-lg-6">
                        <div class="card h-100">
                            <div class="card-body py-2 px-3">
                                @foreach (var match in tie)
                                {
                                    var isEditable = cup.CanEdit && cup.Status != "NotStarted";
                                    <div class="@(tie.Count > 1 ? "mb-2" : "") @(isEditable ? "match-card--editable" : "")"
                                         style="@(isEditable ? "cursor:pointer" : "")"
                                         @onclick="() => HandleMatchClick(match.Id)">
                                        @if (cup.IsHomeAndAway)
                                        {
                                            <span class="badge bg-secondary mb-1" style="font-size:.7rem">@Lang.Get("cup.leg") @match.Leg</span>
                                        }
                                        <MatchDisplay
                                            HomePlayerName="@match.HomePlayerName"
                                            HomePlayerMuted="@string.IsNullOrEmpty(match.HomePlayerId)"
                                            AwayPlayerName="@match.AwayPlayerName"
                                            AwayPlayerMuted="@string.IsNullOrEmpty(match.AwayPlayerId)"
                                            HomeTeamName="@match.HomeTeamName"
                                            AwayTeamName="@match.AwayTeamName"
                                            VideoGameName="@match.VideoGameName"
                                            HomeScore="@match.HomeScore"
                                            AwayScore="@match.AwayScore"
                                            IsPlayed="@(match.Status == "Played")"
                                            WonOnPenaltiesId="@match.WonOnPenaltiesId"
                                            HomePenaltyScore="@match.HomePenaltyScore"
                                            AwayPenaltyScore="@match.AwayPenaltyScore" />
                                        @if (match.ScheduledDate.HasValue && match.Status != "Played")
                                        {
                                            <div class="text-muted small mt-1">📅 @match.ScheduledDate.Value.ToString("dd MMM yyyy")</div>
                                        }

                                        @if (recordingMatchId == match.Id)
                                        {
                                            <div @onclick:stopPropagation="true" @onclick="() => {}">
                                                <MatchResultForm
                                                    HasPenalties="true"
                                                    IsHomeAndAway="cup.IsHomeAndAway"
                                                    IsLeg2="recordingIsLeg2"
                                                    OtherLegHomeScore="otherLegHomeScore"
                                                    OtherLegAwayScore="otherLegAwayScore"
                                                    HomePlayerId="@recordingHomeId"
                                                    HomePlayerName="@match.HomePlayerName"
                                                    AwayPlayerId="@recordingAwayId"
                                                    AwayPlayerName="@match.AwayPlayerName"
                                                    IsSaving="isRecording"
                                                    OnSave="HandleRecordResult"
                                                    OnCancel="() => recordingMatchId = null" />
                                            </div>
                                        }
                                        @if (lastResultMatchId == match.Id && lastEloResult != null)
                                        {
                                            <EloChangeSummary
                                                HomeName="@lastEloResult.Home.DisplayName"
                                                HomeEloChange="@lastEloResult.Home.EloChange"
                                                HomeEloBefore="@lastEloResult.Home.EloBefore"
                                                HomeEloAfter="@lastEloResult.Home.EloAfter"
                                                HomeRankBefore="@lastEloResult.Home.RankBefore"
                                                HomeRankAfter="@lastEloResult.Home.RankAfter"
                                                AwayName="@lastEloResult.Away.DisplayName"
                                                AwayEloChange="@lastEloResult.Away.EloChange"
                                                AwayEloBefore="@lastEloResult.Away.EloBefore"
                                                AwayEloAfter="@lastEloResult.Away.EloAfter"
                                                AwayRankBefore="@lastEloResult.Away.RankBefore"
                                                AwayRankAfter="@lastEloResult.Away.RankAfter" />
                                        }

                                        <MatchEditPanel
                                            IsEditing="editingMatchId == match.Id"
                                            IsLastPlayed="match.IsLastPlayed"
                                            HomePlayerName="@match.HomePlayerName"
                                            AwayPlayerName="@match.AwayPlayerName"
                                            HomeTeamId="match.HomeTeamId"
                                            AwayTeamId="match.AwayTeamId"
                                            VideoGameId="match.VideoGameId"
                                            ScheduledDate="match.ScheduledDate"
                                            Teams="teams"
                                            VideoGames="videoGames"
                                            OnSave="HandlePatchMatch"
                                            OnCancel="() => editingMatchId = null"
                                            OnRequestCorrection="() => HandleRequestCorrection(match.Id)" />
                                        @if (correctingMatchId == match.Id)
                                        {
                                            <div @onclick:stopPropagation="true" @onclick="() => {}">
                                                <MatchResultForm
                                                    HasPenalties="true"
                                                    IsHomeAndAway="cup.IsHomeAndAway"
                                                    IsLeg2="correctingIsLeg2"
                                                    OtherLegHomeScore="correctingOtherLegHomeScore"
                                                    OtherLegAwayScore="correctingOtherLegAwayScore"
                                                    HomePlayerId="@match.HomePlayerId"
                                                    HomePlayerName="@match.HomePlayerName"
                                                    AwayPlayerId="@match.AwayPlayerId"
                                                    AwayPlayerName="@match.AwayPlayerName"
                                                    InitialHomeScore="match.HomeScore"
                                                    InitialAwayScore="match.AwayScore"
                                                    InitialWonOnPenaltiesId="match.WonOnPenaltiesId"
                                                    InitialHomePenaltyScore="match.HomePenaltyScore"
                                                    InitialAwayPenaltyScore="match.AwayPenaltyScore"
                                                    IsSaving="isCorrecting"
                                                    OnSave="HandleCorrectResult"
                                                    OnCancel="() => correctingMatchId = null" />
                                            </div>
                                        }
                                    </div>
                                }

                                @if (cup.IsHomeAndAway && tie.All(m => m.Status == "Played"))
                                {
                                    var agg = ComputeAggregate(tie);
                                    <div class="text-muted small mt-1 border-top pt-1">
                                        @Lang.Get("cup.aggregate"): @agg.homeName @agg.homeGoals – @agg.awayGoals @agg.awayName
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>

            @if (cup.IsManual && cup.CanEdit && cup.Status == "Active")
            {
                @if (addingMatchToRoundId == round.Id)
                {
                    <div class="card mb-3" style="border-color:rgba(34,197,94,.2);background:rgba(34,197,94,.03)" @onclick:stopPropagation="true">
                        <div class="card-body p-3">
                            <div class="row g-2 align-items-end">
                                <div class="col-12 col-sm">
                                    <label class="form-label small mb-1">@Lang.Get("cup.homePlayer")</label>
                                    <select class="form-select form-select-sm" @bind="newMatchHomePlayerId">
                                        <option value="">@Lang.Get("common.select")</option>
                                        @foreach (var p in cup.SeasonPlayers)
                                        {
                                            <option value="@p.Id">@p.DisplayName</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-12 col-sm">
                                    <label class="form-label small mb-1">@Lang.Get("cup.awayPlayer")</label>
                                    <select class="form-select form-select-sm" @bind="newMatchAwayPlayerId">
                                        <option value="">@Lang.Get("common.select")</option>
                                        @foreach (var p in cup.SeasonPlayers)
                                        {
                                            <option value="@p.Id">@p.DisplayName</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-auto">
                                    <label class="form-label small mb-1">@Lang.Get("cup.leg")</label>
                                    <input type="number" class="form-control form-control-sm" style="max-width:70px" min="1" @bind="newMatchLeg" />
                                </div>
                                <div class="col-auto d-flex gap-2">
                                    <button class="btn btn-primary btn-sm" disabled="@isAddingMatch" @onclick="HandleAddMatch">
                                        @if (isAddingMatch)
                                        {
                                            <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                                        }
                                        @Lang.Get("cup.addMatch")
                                    </button>
                                    <button class="btn btn-outline-secondary btn-sm" @onclick="() => addingMatchToRoundId = null">
                                        @Lang.Get("common.cancel")
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <button class="btn btn-outline-primary btn-sm mb-3" @onclick="() => BeginAddMatch(round.Id)">
                        + @Lang.Get("cup.addMatch")
                    </button>
                }
            }
        }

        @if (cup.IsManual && cup.CanEdit && cup.Status == "Active")
        {
            @if (addingRound)
            {
                <div class="d-flex flex-wrap gap-2 align-items-end mt-2 mb-3">
                    <div>
                        <label class="form-label small mb-1">@Lang.Get("cup.roundName")</label>
                        <input type="text" class="form-control form-control-sm" style="width:160px" @bind="newRoundName" placeholder="Final" />
                    </div>
                    <div>
                        <label class="form-label small mb-1">@Lang.Get("cup.roundNumber")</label>
                        <input type="number" class="form-control form-control-sm" style="width:80px" min="1" @bind="newRoundNumber" />
                    </div>
                    <button class="btn btn-primary btn-sm" disabled="@isAddingRound" @onclick="HandleAddRound">
                        @if (isAddingRound)
                        {
                            <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                        }
                        @Lang.Get("cup.addRound")
                    </button>
                    <button class="btn btn-outline-secondary btn-sm" @onclick="() => addingRound = false">
                        @Lang.Get("common.cancel")
                    </button>
                </div>
            }
            else
            {
                <button class="btn btn-outline-secondary btn-sm mt-2" @onclick="BeginAddRound">
                    + @Lang.Get("cup.addRound")
                </button>
            }
        }

        } @* end else (rounds view) *@
    }
}
