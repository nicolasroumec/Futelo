@page "/invitations/{token}/accept"
@inherits LocalizedComponentBase
@attribute [Authorize]

<PageTitle>Accept Invitation - Futelo</PageTitle>

<div class="row justify-content-center mt-5">
    <div class="col-md-4 text-center">
        @if (isLoading)
        {
            <p>@Lang.Get("invitation.processing")</p>
        }
        else if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger">@errorMessage</div>
            <a href="/dashboard" class="btn btn-outline-secondary mt-2">@Lang.Get("invitation.goToDashboard")</a>
        }
        else
        {
            <div class="alert alert-success">@Lang.Get("invitation.joinedSuccess")</div>
            <a href="/dashboard" class="btn btn-primary mt-2">@Lang.Get("invitation.goToDashboard")</a>
        }
    </div>
</div>
