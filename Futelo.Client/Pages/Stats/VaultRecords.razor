@page "/vaults/{vaultId:int}/records"
@inherits LocalizedComponentBase
@attribute [Authorize]

<PageTitle>Records - Futelo</PageTitle>

@if (isLoading)
{
    <div class="d-flex align-items-center gap-3 mb-4">
        <div class="skeleton-block" style="width:3.5rem;height:2rem"></div>
        <div class="skeleton-block" style="width:160px;height:1.75rem"></div>
    </div>
    <div class="d-flex flex-column gap-3" style="max-width:420px">
        <div class="card">
            <div class="card-body">
                <div class="skeleton-block mb-2" style="height:.65rem;width:40%"></div>
                <div class="d-flex justify-content-between align-items-center">
                    <div class="skeleton-block" style="height:1.25rem;width:50%"></div>
                    <div class="skeleton-block" style="height:1.75rem;width:28%;border-radius:1rem"></div>
                </div>
            </div>
        </div>
        <div class="card">
            <div class="card-body">
                <div class="skeleton-block mb-2" style="height:.65rem;width:40%"></div>
                <div class="d-flex justify-content-between align-items-center">
                    <div class="skeleton-block" style="height:1.25rem;width:50%"></div>
                    <div class="skeleton-block" style="height:1.75rem;width:28%;border-radius:1rem"></div>
                </div>
            </div>
        </div>
        <div class="card">
            <div class="card-body">
                <div class="skeleton-block mb-2" style="height:.65rem;width:35%"></div>
                <div class="skeleton-block" style="height:1.25rem;width:65%"></div>
            </div>
        </div>
    </div>
}
else
{
    <div class="d-flex align-items-center gap-3 mb-4">
        <a href="/vaults/@VaultId" class="btn btn-outline-secondary btn-sm">@Lang.Get("common.back")</a>
        <h3 class="mb-0">@Lang.Get("stats.allTimeRecords")</h3>
    </div>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger mb-3">@errorMessage</div>
    }
    else
    {

    @if (standings.Count > 0)
    {
        <h5 class="mb-3">@Lang.Get("stats.allTimeStandings")</h5>
        <div class="table-responsive mb-5" style="max-width:640px">
            <table class="table table-sm table-bordered align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>@Lang.Get("stats.player")</th>
                        <th title="@Lang.Get("stats.played.full")">@Lang.Get("stats.played")</th>
                        <th title="@Lang.Get("stats.wins.full")">@Lang.Get("stats.wins")</th>
                        <th title="@Lang.Get("stats.draws.full")">@Lang.Get("stats.draws")</th>
                        <th title="@Lang.Get("stats.losses.full")">@Lang.Get("stats.losses")</th>
                        <th title="@Lang.Get("stats.goalsFor.full")">@Lang.Get("stats.goalsFor")</th>
                        <th title="@Lang.Get("stats.goalsAgainst.full")">@Lang.Get("stats.goalsAgainst")</th>
                        <th title="@Lang.Get("stats.goalDiff.full")">@Lang.Get("stats.goalDiff")</th>
                        <th title="@Lang.Get("stats.points.full")">@Lang.Get("stats.points")</th>
                        <th title="@Lang.Get("stats.pointsAvg.full")">@Lang.Get("stats.pointsAvg")</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in standings)
                    {
                        <tr class="@(row.Position == 1 ? "rank-gold" : "")">
                            <td>@row.Position</td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <PlayerAvatar Name="@row.DisplayName" Size="24" />
                                    <a href="/vaults/@VaultId/players/@row.PlayerId" class="text-decoration-none">@row.DisplayName</a>
                                </div>
                            </td>
                            <td>@row.Played</td>
                            <td class="text-success fw-semibold">@row.Won</td>
                            <td>@row.Drawn</td>
                            <td class="text-danger">@row.Lost</td>
                            <td>@row.GoalsFor</td>
                            <td>@row.GoalsAgainst</td>
                            <td class="@(row.GoalDifference > 0 ? "text-success" : row.GoalDifference < 0 ? "text-danger" : "")">
                                @(row.GoalDifference > 0 ? $"+{row.GoalDifference}" : row.GoalDifference.ToString())
                            </td>
                            <td><strong>@row.Points</strong></td>
                            <td>@row.PointsAverage.ToString("F3")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    @if (records?.BestWinStreak != null || records?.BestUnbeatenStreak != null || records?.PeakElo != null)
    {
        <h5 class="mb-3">@Lang.Get("stats.allTimeRecords")</h5>
        <div class="row g-3">
            @if (records!.BestWinStreak != null)
            {
                <div class="col-md-6">
                    <div class="card card-glass h-100">
                        <div class="card-body">
                            <div class="text-muted small mb-1">@Lang.Get("stats.bestWinStreak")</div>
                            <div class="d-flex align-items-center justify-content-between">
                                <a href="/vaults/@VaultId/players/@records.BestWinStreak.PlayerId"
                                   class="fw-semibold text-decoration-none fs-5">
                                    @records.BestWinStreak.DisplayName
                                </a>
                                <span class="badge bg-success fs-5">@records.BestWinStreak.Value W</span>
                            </div>
                        </div>
                    </div>
                </div>
            }
            @if (records!.BestUnbeatenStreak != null)
            {
                <div class="col-md-6">
                    <div class="card card-glass h-100">
                        <div class="card-body">
                            <div class="text-muted small mb-1">@Lang.Get("stats.bestUnbeatenRun")</div>
                            <div class="d-flex align-items-center justify-content-between">
                                <a href="/vaults/@VaultId/players/@records.BestUnbeatenStreak.PlayerId"
                                   class="fw-semibold text-decoration-none fs-5">
                                    @records.BestUnbeatenStreak.DisplayName
                                </a>
                                <span class="badge bg-primary fs-5">@records.BestUnbeatenStreak.Value</span>
                            </div>
                        </div>
                    </div>
                </div>
            }
            @if (records!.PeakElo != null)
            {
                <div class="col-md-6">
                    <div class="card card-glass h-100">
                        <div class="card-body">
                            <div class="text-muted small mb-1">@Lang.Get("stats.peakElo")</div>
                            <div class="d-flex align-items-center justify-content-between">
                                <a href="/vaults/@VaultId/players/@records.PeakElo.PlayerId"
                                   class="fw-semibold text-decoration-none fs-5">
                                    @records.PeakElo.DisplayName
                                </a>
                                <span class="badge bg-secondary fs-5">@records.PeakElo.Value</span>
                            </div>
                        </div>
                    </div>
                </div>
            }
            @if (records!.BestEloGain != null)
            {
                <div class="col-md-6">
                    <div class="card card-glass h-100">
                        <div class="card-body">
                            <div class="text-muted small mb-1">@Lang.Get("stats.bestEloGain")</div>
                            <div class="d-flex align-items-center justify-content-between">
                                <a href="/vaults/@VaultId/players/@records.BestEloGain.PlayerId"
                                   class="fw-semibold text-decoration-none fs-5">
                                    @records.BestEloGain.DisplayName
                                </a>
                                <span class="badge bg-info fs-5">+@records.BestEloGain.Value</span>
                            </div>
                        </div>
                    </div>
                </div>
            }
            @if (records!.LongestTop1Reign != null)
            {
                <div class="col-md-6">
                    <div class="card card-glass h-100">
                        <div class="card-body">
                            <div class="text-muted small mb-1">@Lang.Get("stats.longestTop1Reign")</div>
                            <div class="d-flex align-items-center justify-content-between">
                                <a href="/vaults/@VaultId/players/@records.LongestTop1Reign.PlayerId"
                                   class="fw-semibold text-decoration-none fs-5">
                                    @records.LongestTop1Reign.DisplayName
                                </a>
                                <span class="badge bg-warning text-dark fs-5">@records.LongestTop1Reign.Value</span>
                            </div>
                        </div>
                    </div>
                </div>
            }
            @if (records!.TotalMatchesAtTop1 != null)
            {
                <div class="col-md-6">
                    <div class="card card-glass h-100">
                        <div class="card-body">
                            <div class="text-muted small mb-1">@Lang.Get("stats.totalMatchesAtTop1")</div>
                            <div class="d-flex align-items-center justify-content-between">
                                <a href="/vaults/@VaultId/players/@records.TotalMatchesAtTop1.PlayerId"
                                   class="fw-semibold text-decoration-none fs-5">
                                    @records.TotalMatchesAtTop1.DisplayName
                                </a>
                                <span class="badge bg-warning text-dark fs-5">@records.TotalMatchesAtTop1.Value</span>
                            </div>
                        </div>
                    </div>
                </div>
            }
            @if (topScoringMatch != null)
            {
                <div class="col-md-6">
                <div class="card card-glass h-100">
                    <div class="card-body">
                        <div class="text-muted small mb-1">@Lang.Get("stats.topScoringMatch")</div>
                        <div class="d-flex align-items-center justify-content-between">
                            <span class="fw-semibold fs-5">
                                @topScoringMatch.HomePlayerDisplayName @topScoringMatch.HomeScore – @topScoringMatch.AwayScore @topScoringMatch.AwayPlayerDisplayName
                            </span>
                            <span class="badge bg-warning text-dark fs-5">@topScoringMatch.TotalGoals @Lang.Get("stats.goalsLabel")</span>
                        </div>
                        @if (!string.IsNullOrEmpty(topScoringMatch.SeasonName))
                        {
                            <div class="text-muted small mt-1">@topScoringMatch.SeasonName</div>
                        }
                    </div>
                </div>
                </div>
            }
        </div>
    }
    }
}
