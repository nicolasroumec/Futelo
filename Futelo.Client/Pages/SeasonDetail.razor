@page "/seasons/{id:int}"
@inherits LocalizedComponentBase
@attribute [Authorize]

<PageTitle>@(season?.Name ?? "Season") - Futelo</PageTitle>

@if (isLoading)
{
    <div class="d-flex align-items-center gap-3 mb-4">
        <div class="skeleton-block" style="width:3.5rem;height:2rem"></div>
        <div class="skeleton-block" style="width:160px;height:1.75rem"></div>
        <div class="skeleton-block" style="width:4.5rem;height:1.5rem;border-radius:1rem"></div>
    </div>
    <div class="skeleton-block mb-2" style="width:120px;height:.75rem"></div>
    <div class="skeleton-block mb-4" style="width:150px;height:.75rem"></div>
    <div class="d-flex gap-2 mb-4">
        <div class="skeleton-block" style="width:5rem;height:2rem"></div>
        <div class="skeleton-block" style="width:5rem;height:2rem"></div>
    </div>
    <div class="d-flex gap-2 mb-4">
        <div class="skeleton-block" style="width:5.5rem;height:1.5rem;border-radius:1rem"></div>
        <div class="skeleton-block" style="width:4.5rem;height:1.5rem;border-radius:1rem"></div>
    </div>
    <div class="skeleton-block mb-2" style="width:70px;height:1rem"></div>
    <ul class="list-group" style="max-width:520px">
        <li class="list-group-item"><div class="skeleton-block" style="height:.8rem;width:60%"></div></li>
        <li class="list-group-item"><div class="skeleton-block" style="height:.8rem;width:75%"></div></li>
        <li class="list-group-item"><div class="skeleton-block" style="height:.8rem;width:50%"></div></li>
        <li class="list-group-item"><div class="skeleton-block" style="height:.8rem;width:65%"></div></li>
    </ul>
}
else if (season == null)
{
    <p class="text-danger">@Lang.Get("season.notFound")</p>
}
else
{
    <div class="d-flex align-items-center gap-3 mb-4">
        <a href="/vaults/@season.VaultId" class="btn btn-outline-secondary btn-sm">@Lang.Get("common.back")</a>
        <h3 class="mb-0">@season.Name</h3>
        <span class="badge @BadgeHelper.StatusBadgeClass(season.Status)">@Lang.Get("season.status." + season.Status.ToLower())</span>
    </div>

    <p class="text-muted">@Lang.Get("season.year"): @season.Year</p>
    <p class="text-muted">@Lang.Get("season.videoGame"): @(season.VideoGameName ?? "—")</p>

    @if (isOwner && (season.Status == "Draft" || season.Status == "Active"))
    {
        <div class="d-flex align-items-center gap-2 mb-3" style="max-width:420px">
            <select class="form-select form-select-sm" @bind="selectedVideoGameId">
                <option value="">@Lang.Get("common.none")</option>
                @foreach (var g in videoGames)
                {
                    <option value="@g.Id">@g.Name</option>
                }
            </select>
            <button class="btn btn-outline-primary btn-sm" disabled="@isPatchingVideoGame"
                    @onclick="HandlePatchVideoGame">
                @(isPatchingVideoGame ? Lang.Get("common.saving") : Lang.Get("common.save"))
            </button>
        </div>
        @if (!string.IsNullOrEmpty(videoGameMessage))
        {
            <div class="alert @videoGameAlertClass mb-3" style="max-width:420px">@videoGameMessage</div>
        }
    }

    <div class="d-flex gap-2 mb-3">
        <a href="/vaults/@season.VaultId/seasons/@season.Id/ranking" class="btn btn-outline-secondary btn-sm">@Lang.Get("stats.ranking")</a>
        @if (isOwner && season.Status == "Active")
        {
            <button class="btn btn-outline-danger btn-sm" disabled="@(!CanFinish || isFinishing)"
                    @onclick="HandleFinish">
                @(isFinishing ? Lang.Get("season.finishing") : Lang.Get("season.finishSeason"))
            </button>
        }
        @if (isOwner)
        {
            @if (!confirmDelete)
            {
                <button class="btn btn-outline-danger btn-sm ms-auto"
                        @onclick="() => confirmDelete = true">
                    @Lang.Get("season.deleteSeason")
                </button>
            }
            else
            {
                <span class="ms-auto d-flex align-items-center gap-2">
                    <small class="text-danger">@Lang.Get("season.deleteConfirm")</small>
                    <button class="btn btn-danger btn-sm" disabled="@isDeleting"
                            @onclick="HandleDelete">
                        @(isDeleting ? Lang.Get("common.deleting") : Lang.Get("common.confirmDelete"))
                    </button>
                    <button class="btn btn-outline-secondary btn-sm"
                            @onclick="() => confirmDelete = false">
                        @Lang.Get("common.cancel")
                    </button>
                </span>
            }
        }
    </div>

    @if (!string.IsNullOrEmpty(finishMessage))
    {
        <div class="alert @finishAlertClass mb-3" style="max-width:420px">@finishMessage</div>
    }

    @if (isOwner && season.Status == "Active" && !CanFinish)
    {
        <div class="alert alert-warning mb-3" style="max-width:420px">
            @Lang.Get("season.finishWarning")
        </div>
    }

    <div class="d-flex gap-2 mb-4">
        @if (season.HasLeague)
        {
            @if (season.LeagueId.HasValue)
            {
                <a href="/leagues/@season.LeagueId" class="badge bg-primary text-decoration-none">@season.LeagueName</a>
            }
            else
            {
                <span class="badge bg-primary">@season.LeagueName</span>
            }
        }
        @if (season.HasCup)
        {
            @if (season.CupId.HasValue)
            {
                <a href="/cups/@season.CupId" class="badge bg-success text-decoration-none">@season.CupName</a>
            }
            else
            {
                <span class="badge bg-success">@season.CupName</span>
            }
        }
        @if (season.HasSuperCup)
        {
            @if (season.SuperCupId.HasValue)
            {
                <a href="/supercups/@season.SuperCupId" class="badge bg-warning text-dark text-decoration-none">@season.SuperCupName</a>
            }
            else
            {
                <span class="badge bg-warning text-dark">@season.SuperCupName</span>
            }
        }
    </div>

    <div class="row g-4">
        <div class="@(HasRightContent ? "col-lg-5" : "col-12")">
            <h5>@Lang.Get("season.players")</h5>
            @if (season.Players.Count == 0)
            {
                <p class="empty-state">@Lang.Get("season.noPlayers")</p>
            }
            else
            {
                <ul class="list-group mb-4">
                    @foreach (var p in season.Players)
                    {
                        <li class="list-group-item" @key="@p.PlayerId">
                            <div class="d-flex justify-content-between align-items-center">
                                <span>@p.DisplayName</span>
                                <span class="badge bg-light text-dark">ELO @p.SeasonElo</span>
                            </div>
                            @if (isOwner && (season.Status == "Draft" || season.Status == "Active"))
                            {
                                <SeasonTeamSelector InitialTeamId="@p.TeamId"
                                                    Teams="@teams"
                                                    OnSave="@(teamId => HandleSetPlayerTeam(p.PlayerId, teamId))" />
                            }
                            else if (!string.IsNullOrEmpty(p.TeamName))
                            {
                                <small class="text-muted">@p.TeamName</small>
                            }
                        </li>
                    }
                </ul>
            }
        </div>

        @if (HasRightContent)
        {
            <div class="col-lg-7">
                @if (season.TopStandings.Count > 0)
                {
                    <h5>@Lang.Get("league.standings")</h5>
                    <div class="table-responsive mb-4">
                        <table class="table table-sm table-bordered align-middle">
                            <thead class="table-dark">
                                <tr>
                                    <th>#</th>
                                    <th>@Lang.Get("stats.player")</th>
                                    <th>@Lang.Get("stats.played")</th>
                                    <th>@Lang.Get("stats.wins")</th>
                                    <th>@Lang.Get("stats.draws")</th>
                                    <th>@Lang.Get("stats.losses")</th>
                                    <th>@Lang.Get("league.points")</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{ int pos = 1; }
                                @foreach (var row in season.TopStandings)
                                {
                                    <tr class="@(pos == 1 ? "rank-gold" : "")">
                                        <td>@pos</td>
                                        <td>@row.DisplayName</td>
                                        <td>@row.Played</td>
                                        <td>@row.Won</td>
                                        <td>@row.Drawn</td>
                                        <td>@row.Lost</td>
                                        <td><strong>@row.Points</strong></td>
                                    </tr>
                                    pos++;
                                }
                            </tbody>
                        </table>
                    </div>
                }

                @if (season.RecentMatches.Count > 0)
                {
                    <h5>@Lang.Get("vault.recentMatches")</h5>
                    <div class="d-flex flex-column gap-2 mb-4">
                        @foreach (var m in season.RecentMatches)
                        {
                            <div class="recent-match-row">
                                <span class="recent-match-competition text-muted small">@m.Competition</span>
                                <MatchDisplay HomePlayerName="@m.HomePlayerName"
                                              AwayPlayerName="@m.AwayPlayerName"
                                              HomeScore="@m.HomeScore"
                                              AwayScore="@m.AwayScore"
                                              IsPlayed="true" />
                            </div>
                        }
                    </div>
                }

                @if (isOwner && season.Status == "Draft")
                {
                    <h5>@Lang.Get("season.configureSeason")</h5>

                    <SeasonPlayerManager VaultPlayers="@vaultPlayers" SelectedPlayerIds="@selectedPlayerIds" />

                    <SeasonCompetitionConfig Model="@configureModel" />

                    @if (!string.IsNullOrEmpty(configureMessage))
                    {
                        <div class="alert @configureAlertClass" style="max-width:420px">@configureMessage</div>
                    }

                    <button class="btn btn-primary" disabled="@isConfiguring" @onclick="HandleConfigure">
                        @(isConfiguring ? Lang.Get("common.saving") : Lang.Get("season.saveConfig"))
                    </button>

                    @if (season.Players.Count >= 2 && (season.HasLeague || season.HasCup))
                    {
                        <div class="mt-3">
                            @if (!string.IsNullOrEmpty(activateMessage))
                            {
                                <div class="alert @activateAlertClass mb-2" style="max-width:420px">@activateMessage</div>
                            }
                            <button class="btn btn-success" disabled="@isActivating" @onclick="HandleActivate">
                                @(isActivating ? Lang.Get("season.activating") : Lang.Get("season.startSeason"))
                            </button>
                        </div>
                    }
                }
            </div>
        }
    </div>
}

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger mt-3">@errorMessage</div>
}
