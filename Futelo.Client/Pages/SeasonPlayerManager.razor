@inherits LocalizedComponentBase

<div class="mb-3">
    <label class="form-label fw-semibold">@Lang.Get("season.players")</label>
    <div class="d-flex flex-wrap gap-2 mt-1">
        @foreach (var vp in VaultPlayers)
        {
            var pid = vp.PlayerId;
            bool isSelected = SelectedPlayerIds.Contains(pid);
            <button @key="pid" type="button"
                    class="player-chip @(isSelected ? "player-chip--on" : "player-chip--off")"
                    @onclick="() => Toggle(pid)">
                @if (isSelected)
                {
                    <span class="me-1" aria-hidden="true">✓</span>
                }
                @vp.DisplayName
            </button>
        }
    </div>
    <div class="mt-2 text-muted" style="font-size:.75rem">
        @SelectedPlayerIds.Count @Lang.Get("season.playersSelected")
    </div>
</div>
