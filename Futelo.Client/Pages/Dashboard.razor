@page "/dashboard"
@attribute [Authorize]

<PageTitle>Dashboard - Futelo</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3>@Lang.Get("dashboard.title")</h3>
    <a href="/vaults/create" class="btn btn-primary">@Lang.Get("dashboard.newVault")</a>
</div>

@if (isLoading)
{
    <SkeletonCards Count="3" Columns="3" />
}
else if (vaults.Count == 0)
{
    <div class="card card-glass text-center py-5" style="max-width:480px">
        <div class="card-body">
            <h4 class="card-title mb-2">@Lang.Get("dashboard.emptyTitle")</h4>
            <p class="card-text mb-4">@Lang.Get("dashboard.emptySubtitle")</p>
            <a href="/vaults/create" class="btn btn-primary">@Lang.Get("dashboard.newVault")</a>
        </div>
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-3 g-4">
        @foreach (var vault in vaults)
        {
            <div class="col">
                <div class="card card-glass h-100">
                    <div class="card-body">
                        <h5 class="card-title">@vault.Name</h5>
                        <p class="card-text text-muted">@Lang.Get("common.owner"): @vault.OwnerDisplayName</p>
                        <p class="card-text"><small>@vault.Players.Count @Lang.Get("dashboard.players")</small></p>
                    </div>
                    <div class="card-footer">
                        <a href="/vaults/@vault.Id" class="btn btn-outline-primary btn-sm">@Lang.Get("dashboard.open")</a>
                    </div>
                </div>
            </div>
        }
    </div>
}

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger mt-3">@errorMessage</div>
}
